@model IEnumerable<AutoHub.Models.Entities.SparePart>

@{
    ViewData["Title"] = "Quan ly phu tung - AutoHub";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Quan ly phu tung</h1>
    <a href="@Url.Action("Create", "SparePart", new { area = "Admin" })" class="btn-neon text-decoration-none">Them phu tung</a>
</div>

<div class="tech-panel">
    <table class="table table-hover align-middle">
        <thead>
            <tr class="text-uppercase text-muted" style="font-size:0.8rem;">
                <th>Ten phu tung</th>
                <th>Hang</th>
                <th>Danh muc</th>
                <th>Tuong thich xe</th>
                <th>Trang thai</th>
                <th>Gia nhap</th>
                <th>Gia ban</th>
                <th>Ton kho</th>
                <th class="text-end">Thao tac</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var part in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold">@part.Name</div>
                        @if (part.ManufactureYear.HasValue)
                        {
                            <div class="text-muted" style="font-size:0.8rem;">Nam SX: @part.ManufactureYear</div>
                        }
                    </td>
                    <td><span class="badge bg-secondary py-2 px-3">@(part.Brand?.Name ?? "N/A")</span></td>
                    <td><span class="badge bg-dark">@(part.CategoryMaster?.Name ?? part.Category)</span></td>
                    <td>
                        @if (part.Compatibilities.Any())
                        {
                            foreach (var item in part.Compatibilities)
                            {
                                <div style="font-size:0.85rem;">
                                    @item.VehicleName.Name
                                    @if (item.VehicleVariant != null)
                                    {
                                        <span> @item.VehicleVariant.Name</span>
                                    }
                                    @if (item.VehicleModelYear != null)
                                    {
                                        <span> - @item.VehicleModelYear.Year</span>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted" style="font-size:0.85rem;">Chua gan</span>
                        }
                    </td>
                    <td>
                        @if (part.Status == "Incoming")
                        {
                            <span class="badge bg-warning text-dark">Dang ve hang</span>
                        }
                        else if (part.Status == "OutOfStock")
                        {
                            <span class="badge bg-danger">Het hang</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Dang ban</span>
                        }
                    </td>
                    <td class="text-secondary fw-semibold">@string.Format("{0:N0}", part.CostPrice) d</td>
                    <td class="text-success fw-bold">@string.Format("{0:N0}", part.Price) d</td>
                    <td>@part.StockQuantity cai</td>
                    <td class="text-end">
                        <form method="post" action="@Url.Action("Delete", "SparePart", new { area = "Admin", id = part.Id })" style="display:inline;" onsubmit="return confirm('Ban co chac chan muon xoa phu tung nay?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger border-0">Xoa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
