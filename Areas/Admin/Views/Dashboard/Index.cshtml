@{
    ViewData["Title"] = "Báo Cáo Doanh Thu & Vận Hành - AutoHub";
    Layout = "_AdminLayout";
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    int totalVehicles = ViewBag.TotalVehiclesInStock ?? 0;
    int totalBrands = ViewBag.TotalBrands ?? 0;
    int totalSpareParts = ViewBag.TotalSpareParts ?? 0;
    var recentOrders = (IEnumerable<AutoHub.Models.Entities.Order>)ViewBag.RecentOrders;
}

@section Styles {
    <style>
        .stat-card {
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.03);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            border: 1px solid rgba(17, 17, 17, 0.08);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
        }
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
        }
        .chart-container {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            height: 200px;
            padding: 1rem 0;
            border-bottom: 2px solid rgba(17, 17, 17, 0.08);
        }
        .chart-bar-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-grow: 1;
            max-width: 60px;
        }
        .chart-bar {
            width: 32px;
            background-color: var(--text-piano);
            border-radius: 4px 4px 0 0;
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
            position: relative;
        }
        .chart-bar:hover {
            background-color: var(--accent-ferrari);
        }
        .chart-bar:hover::after {
            content: attr(data-value);
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            background: #111;
            color: #fff;
            padding: 2px 6px;
            font-size: 0.75rem;
            border-radius: 4px;
            white-space: nowrap;
            font-weight: bold;
            z-index: 10;
        }
        .chart-label {
            font-size: 0.75rem;
            color: #666;
            margin-top: 8px;
            font-weight: 600;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Hệ Thống Tổng Quan Vận Hành</h1>
    <!-- <span class="badge bg-dark py-2 px-3 text-uppercase" style="letter-spacing: 1px; font-weight:700;">Admin Mode</span> -->
</div>

            <!-- Hàng Thẻ Thống Kê Số Liệu -->
            <div class="row g-4 mb-5">
                <div class="col-md-6 col-lg-3">
                    <div class="stat-card d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase fw-bold" style="font-size:0.75rem; letter-spacing:0.5px;">Tổng Doanh Thu</span>
                            <h3 class="fw-bold mt-1 text-danger mb-0">@totalRevenue.ToString("N0") đ</h3>
                        </div>
                        <div class="stat-icon bg-danger-subtle text-danger">💸</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="stat-card d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase fw-bold" style="font-size:0.75rem; letter-spacing:0.5px;">Xe Trong Kho</span>
                            <h3 class="fw-bold mt-1 mb-0">@totalVehicles chiếc</h3>
                        </div>
                        <div class="stat-icon bg-dark-subtle text-dark">🚗</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="stat-card d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase fw-bold" style="font-size:0.75rem; letter-spacing:0.5px;">Thương Hiệu</span>
                            <h3 class="fw-bold mt-1 text-warning mb-0">@totalBrands hãng</h3>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning" style="color: #d4af37 !important;">🏷️</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="stat-card d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase fw-bold" style="font-size:0.75rem; letter-spacing:0.5px;">Linh Kiện</span>
                            <h3 class="fw-bold mt-1 text-primary mb-0">@totalSpareParts loại</h3>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">🛠️</div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Biểu đồ Doanh thu (CSS Cột) -->
                <div class="col-lg-5">
                    <div class="tech-panel h-100">
                        <h4 class="text-uppercase mb-4 fw-bold fs-5" style="letter-spacing: -0.5px;">Biểu Đồ Doanh Thu Định Kỳ</h4>
                        <p class="text-muted small mb-4">Mô phỏng báo cáo doanh số bán xe & phụ tùng thực tế theo quý năm 2026 (Đơn vị: Triệu đồng).</p>
                        
                        <div class="chart-container">
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar" style="height: 35%;" data-value="1.050 Tr"></div>
                                <span class="chart-label">Tháng 2</span>
                            </div>
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar" style="height: 10%;" data-value="0 Tr"></div>
                                <span class="chart-label">Tháng 3</span>
                            </div>
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar" style="height: 65%;" data-value="1.980 Tr"></div>
                                <span class="chart-label">Tháng 4</span>
                            </div>
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar" style="height: 85%;" data-value="2.701 Tr"></div>
                                <span class="chart-label">Tháng 5</span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-3 text-muted small">
                            <span>Thấp nhất: 0 đ</span>
                            <span>Cao nhất: 2,7 Tỷ đ</span>
                        </div>
                    </div>
                </div>

                <!-- Đơn Hàng Gần Đây -->
                <div class="col-lg-7">
                    <div class="tech-panel h-100">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="text-uppercase fw-bold fs-5 mb-0" style="letter-spacing: -0.5px;">Đơn Hàng Gần Đây</h4>
                            <span class="badge bg-secondary">Mới Cập Nhật</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr class="text-uppercase text-muted" style="font-size:0.75rem;">
                                        <th>Khách Hàng</th>
                                        <th>Ngày Đặt</th>
                                        <th>Tổng Giá Trị</th>
                                        <th class="text-end">Hóa Đơn</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (recentOrders != null && recentOrders.Any())
                                    {
                                        foreach (var order in recentOrders)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="fw-bold">@order.CustomerName</div>
                                                </td>
                                                <td>
                                                    <span class="text-muted small">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                                                </td>
                                                <td>
                                                    <span class="fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</span>
                                                </td>
                                                <td class="text-end">
                                                    <span class="badge bg-success-subtle text-success py-1 px-2 text-uppercase" style="font-size: 0.7rem; font-weight:700;">Thành công</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">Hệ thống chưa có phát sinh giao dịch nào.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

