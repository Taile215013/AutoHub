@model AutoHub.Models.Entities.Vehicle

@{
    ViewData["Title"] = "Sua xe - AutoHub";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Sua xe</h1>
    <a href="@Url.Action("Index", "Vehicle", new { area = "Admin" })" class="btn-neon text-white text-decoration-none">Quay lai</a>
</div>

<div class="tech-panel">
    <form method="post" action="@Url.Action("Edit", "Vehicle", new { area = "Admin", id = Model.Id })" enctype="multipart/form-data">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="row g-4">
            
            <!-- Khu vực 1: Tên & Phiên Bản -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">1. Tên & Phiên Bản Xe</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tên xe gốc đã có</label>
                        <select name="vehicleNameId" class="form-select border-secondary py-2">
                            <option value="">-- Tạo tên xe mới --</option>
                            @if (ViewBag.VehicleNames != null)
                            {
                                foreach (var vehicleName in ViewBag.VehicleNames)
                                {
                                    <option value="@vehicleName.Id" selected="@(Model.VehicleNameId == vehicleName.Id)">@vehicleName.Brand.Name - @vehicleName.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tên xe mới nếu chưa có</label>
                        <input type="text" name="newVehicleName" class="form-control border-secondary py-2" placeholder="Ví dụ: Airblade, Civic, Camry" />
                        <input type="hidden" name="Name" value="@Model.Name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Phiên bản / Phân khối</label>
                        <input type="text" name="variantName" class="form-control border-secondary py-2" value="@Model.VehicleVariant?.Name" placeholder="Ví dụ: 125, 150, 160" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Năm đời xe</label>
                        <input type="number" name="modelYear" class="form-control border-secondary py-2" value="@Model.VehicleModelYear?.Year" min="1900" max="2100" />
                    </div>
                </div>
            </div>

            <!-- Khu vực 2: Hãng & Phân Loại -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">2. Hãng & Phân Loại</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Hãng sản xuất</label>
                        <select name="BrandId" class="form-select border-secondary py-2" required>
                            @if (ViewBag.Brands != null)
                            {
                                foreach (var brand in ViewBag.Brands)
                                {
                                    <option value="@brand.Id" selected="@(Model.BrandId == brand.Id)">@brand.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Phân loại</label>
                        <select name="VehicleType" class="form-select border-secondary py-2" required>
                            @if (ViewBag.VehicleTypes != null)
                            {
                                foreach (var type in ViewBag.VehicleTypes)
                                {
                                    <option value="@type.Code" selected="@(Model.VehicleType == type.Code)">@type.Value</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Khu vực 3: Thông số kỹ thuật -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">3. Thông Số Kỹ Thuật</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Nhiên liệu</label>
                        <select name="FuelType" class="form-select border-secondary py-2" required>
                            @if (ViewBag.FuelTypes != null)
                            {
                                foreach (var fuel in ViewBag.FuelTypes)
                                {
                                    <option value="@fuel.Code" selected="@(Model.FuelType == fuel.Code)">@fuel.Value</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Hộp số</label>
                        <select name="Transmission" class="form-select border-secondary py-2" required>
                            @if (ViewBag.Transmissions != null)
                            {
                                foreach (var trans in ViewBag.Transmissions)
                                {
                                    <option value="@trans.Code" selected="@(Model.Transmission == trans.Code)">@trans.Value</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Loại động cơ</label>
                        <select name="EngineType" class="form-select border-secondary py-2" required>
                            @if (ViewBag.EngineTypes != null)
                            {
                                foreach (var engine in ViewBag.EngineTypes)
                                {
                                    <option value="@engine.Code" selected="@(Model.EngineType == engine.Code)">@engine.Value</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Dung tích động cơ</label>
                        <input type="number" step="0.1" name="EngineCapacity" value="@Model.EngineCapacity" class="form-control border-secondary py-2" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Số chỗ ngồi</label>
                        <input type="number" name="SeatingCapacity" value="@Model.SeatingCapacity" class="form-control border-secondary py-2" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Dáng xe</label>
                        <select name="BodyStyle" class="form-select border-secondary py-2" required>
                            @if (ViewBag.BodyStyles != null)
                            {
                                foreach (var body in ViewBag.BodyStyles)
                                {
                                    <option value="@body.Code" selected="@(Model.BodyStyle == body.Code)">@body.Value</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Trọng lượng (kg)</label>
                        <input type="number" step="0.1" name="Weight" value="@Model.Weight" class="form-control border-secondary py-2" />
                    </div>
                </div>
            </div>

            <!-- Khu vực 4: Tồn kho -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">4. Tồn Kho</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Số lượng tồn kho</label>
                        <input type="number" name="Quantity" value="@Model.Quantity" class="form-control border-secondary py-2" />
                    </div>
                </div>
            </div>

            <!-- Khu vực 5: Hình ảnh -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">5. Hình Ảnh</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-warning" style="font-size:0.8rem; font-weight:700;">📷 Đổi ảnh bìa (Thumbnail)</label>
                        @if (!string.IsNullOrEmpty(Model.ThumbnailImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ThumbnailImageUrl" alt="Thumbnail hiện tại" class="img-fluid rounded border border-warning" style="max-height:100px;" />
                                <small class="text-muted d-block">Ảnh bìa hiện tại</small>
                            </div>
                        }
                        <input type="file" name="thumbnailFile" accept="image/*" class="form-control bg-dark text-white border-warning py-2" id="thumbnailInput" />
                        <div class="mt-2 text-center d-none" id="thumbnailPreview">
                            <img id="thumbnailImg" src="#" alt="Preview" class="img-fluid rounded border border-warning" style="max-height:100px;" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-info" style="font-size:0.8rem; font-weight:700;">🖼️ Đổi ảnh gốc chất lượng cao</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ImageUrl" alt="Ảnh gốc hiện tại" class="img-fluid rounded border border-info" style="max-height:100px;" />
                                <small class="text-muted d-block">Ảnh gốc hiện tại</small>
                            </div>
                        }
                        <input type="file" name="uploadedFile" accept="image/*" class="form-control bg-dark text-white border-info py-2" id="imageInput" />
                        <div class="mt-2 text-center d-none" id="previewContainer">
                            <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded border border-info" style="max-height:100px;" />
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label text-uppercase text-success" style="font-size:0.8rem; font-weight:700;">🖼️ Thêm ảnh bổ sung (chọn nhiều ảnh)</label>
                        @if (!string.IsNullOrEmpty(Model.AdditionalImages))
                        {
                            <div class="mb-2 d-flex flex-wrap gap-2">
                                @foreach (var imgUrl in System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.AdditionalImages) ?? new List<string>())
                                {
                                    <img src="@imgUrl" alt="Ảnh bổ sung" class="img-fluid rounded border border-success" style="max-height:80px; max-width:100px; object-fit:cover;" />
                                }
                                <small class="text-muted d-block w-100">Ảnh bổ sung hiện tại (chọn file mới sẽ thay thế)</small>
                            </div>
                        }
                        <input type="file" name="additionalFiles" accept="image/*" multiple class="form-control bg-dark text-white border-success py-2" id="additionalInput" />
                        <div class="mt-2 d-flex flex-wrap gap-2 d-none" id="additionalPreview"></div>
                    </div>
                </div>
            </div>

            <!-- Khu vực 6: Giá bán -->
            <div class="col-12">
                <h5 class="text-warning mb-3 border-bottom border-secondary pb-2" style="font-weight:800;">6. Giá Bán (VNĐ)</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-danger" style="font-size:0.8rem; font-weight:700;">Giá thu vào</label>
                        <input type="number" step="0.01" name="PurchasePrice" value="@Model.PurchasePrice" class="form-control border-danger py-2" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-uppercase text-success" style="font-size:0.8rem; font-weight:700;">Giá bán ra</label>
                        <input type="number" step="0.01" name="CurrentPrice" value="@Model.CurrentPrice" class="form-control border-success py-2" required />
                    </div>
                </div>
            </div>

            <div class="col-12 mt-5">
                <button type="submit" class="btn-neon w-100 py-3">Luu thay doi</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function previewSingleImage(inputId, previewContainerId, previewImgId) {
            $(inputId).change(function(e) {
                var file = e.target.files[0];
                if (!file) { $(previewContainerId).addClass('d-none'); return; }
                var reader = new FileReader();
                reader.onload = function(event) {
                    $(previewImgId).attr('src', event.target.result);
                    $(previewContainerId).removeClass('d-none');
                };
                reader.readAsDataURL(file);
            });
        }

        $(document).ready(function() {
            previewSingleImage('#thumbnailInput', '#thumbnailPreview', '#thumbnailImg');
            previewSingleImage('#imageInput', '#previewContainer', '#imagePreview');

            $('#additionalInput').change(function(e) {
                var container = $('#additionalPreview');
                container.empty();
                if (e.target.files.length === 0) { container.addClass('d-none'); return; }
                container.removeClass('d-none');
                Array.from(e.target.files).forEach(function(file) {
                    var reader = new FileReader();
                    reader.onload = function(event) {
                        container.append('<img src="' + event.target.result + '" class="img-fluid rounded border border-success" style="max-height:80px; max-width:100px; object-fit:cover;" />');
                    };
                    reader.readAsDataURL(file);
                });
            });
        });
    </script>
}

