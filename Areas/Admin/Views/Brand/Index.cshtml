@model IEnumerable<AutoHub.Models.Entities.Brand>

@{
    ViewData["Title"] = "Quản Lý Thương Hiệu - AutoHub";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        @@keyframes highlightMint {
            0% { background-color: rgba(46, 229, 157, 0.4); }
            100% { background-color: transparent; }
        }
        @@keyframes highlightGold {
            0% { background-color: rgba(212, 175, 55, 0.4); }
            100% { background-color: transparent; }
        }
        .row-highlight-add {
            animation: highlightMint 2s ease-out;
        }
        .row-highlight-edit {
            animation: highlightGold 2s ease-out;
        }
        .table-hover tbody tr {
            transition: all 0.3s ease;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Quản Lý Thương Hiệu</h1>
    <button type="button" class="btn-neon" onclick="openAddBrandModal()">Thêm Hãng Mới</button>
</div>

            <div class="tech-panel">
                <table class="table table-hover align-middle" id="brandsTable">
                    <thead>
                        <tr class="text-uppercase text-muted" style="font-size:0.8rem;">
                            <th>Tên Thương Hiệu</th>
                            <th>Quốc Gia</th>
                            <th>Lĩnh Vực Hoạt Động</th>
                            <th class="text-end" style="width: 150px;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="brandsTableBody">
                        @foreach (var brand in Model)
                        {
                            <tr id="brand-row-@brand.Id" 
                                data-id="@brand.Id" 
                                data-name="@brand.Name" 
                                data-country="@brand.CountryId" 
                                data-vehicle="@brand.IsVehicleBrand.ToString().ToLower()" 
                                data-part="@brand.IsPartBrand.ToString().ToLower()" 
                                data-toy="@brand.IsToyBrand.ToString().ToLower()"
                                data-image="@brand.ImageUrl">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(brand.ImageUrl))
                                        {
                                            <img src="@brand.ImageUrl" alt="@brand.Name"
                                                 class="brand-logo-cell"
                                                 style="width:42px; height:42px; object-fit:contain; border-radius:6px; border:1px solid rgba(255,255,255,0.1); background:#fff; flex-shrink:0; padding:3px;" />
                                        }
                                        else
                                        {
                                            <div style="width:42px; height:42px; background:rgba(255,255,255,0.06); border-radius:6px; border:1px solid rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                                <span style="font-size:1.1rem; opacity:0.4;">🏷️</span>
                                            </div>
                                        }
                                        <div class="fw-bold fs-5 brand-name-cell">@brand.Name</div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary py-2 px-3 brand-country-cell">@(brand.Country != null ? brand.Country.Name : "N/A")</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2 brand-scopes-cell">
                                        @if (brand.IsVehicleBrand)
                                        {
                                            <span class="badge bg-danger text-uppercase badge-vehicle" style="font-size:0.75rem;">Sản Xuất Xe</span>
                                        }
                                        @if (brand.IsPartBrand)
                                        {
                                            <span class="badge bg-primary text-uppercase badge-part" style="font-size:0.75rem;">Sản Xuất Phụ Tùng</span>
                                        }
                                        @if (brand.IsToyBrand)
                                        {
                                            <span class="badge bg-warning text-dark text-uppercase badge-toy" style="font-size:0.75rem;">Sản Xuất Đồ Chơi</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-warning border-0 me-1 fw-bold" onclick="openEditBrandModal(@brand.Id)">Sửa</button>
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 fw-bold" onclick="deleteBrandAjax(@brand.Id)">Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

<!-- Modal Thêm/Sửa Thương Hiệu -->
<div class="modal fade" id="brandModal" tabindex="-1" aria-labelledby="brandModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: rgba(30,30,40,0.95); backdrop-filter: blur(10px); color: #fff;">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold text-uppercase" id="brandModalLabel" style="letter-spacing: 1px;">Cập Nhật Thương Hiệu</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="brandForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="brandId" value="0" />
                    
                    <div class="alert alert-danger d-none" id="errorMessage"></div>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase fw-bold" style="font-size:0.8rem;">Tên Hãng</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" id="brandName" required placeholder="Nhập tên hãng...">
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted text-uppercase fw-bold" style="font-size:0.8rem;">Quốc Gia</label>
                        <select class="form-select bg-dark text-white border-secondary" id="brandCountry" required>
                            @if (ViewBag.Countries != null)
                            {
                                foreach (var country in ViewBag.Countries)
                                {
                                    <option value="@country.Id">@country.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted text-uppercase fw-bold" style="font-size:0.8rem;">Ảnh Logo (Tùy Chọn)</label>
                        <input type="file" class="form-control bg-dark text-white border-secondary" id="brandImage" accept="image/*">
                    </div>

                    <label class="form-label text-muted text-uppercase fw-bold mb-3" style="font-size:0.8rem;">Lĩnh Vực Hoạt Động</label>
                    <div class="d-flex flex-column gap-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isVehicleBrand">
                            <label class="form-check-label" for="isVehicleBrand">Sản Xuất Xe</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isPartBrand">
                            <label class="form-check-label" for="isPartBrand">Sản Xuất Phụ Tùng</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isToyBrand">
                            <label class="form-check-label" for="isToyBrand">Sản Xuất Đồ Chơi</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-neon border-0">Lưu Thông Tin</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toast Thông báo -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
    <div id="appToast" class="toast align-items-center text-white bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-bold" id="toastMessage">
                Thao tác thành công!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Khởi tạo Bootstrap Elements
        var brandModal;
        var appToast;

        $(document).ready(function() {
            brandModal = new bootstrap.Modal(document.getElementById('brandModal'));
            appToast = new bootstrap.Toast(document.getElementById('appToast'), { delay: 3500 });
            
            // Xử lý submit form thêm/sửa bằng AJAX
            $('#brandForm').on('submit', function(e) {
                e.preventDefault();
                $('#errorMessage').addClass('d-none').text('');

                // Thu thập dữ liệu form bằng FormData để xử lý file
                var formData = new FormData();
                formData.append('Id', parseInt($('#brandId').val()) || 0);
                formData.append('Name', $('#brandName').val().trim());
                formData.append('CountryId', parseInt($('#brandCountry').val()));
                formData.append('IsVehicleBrand', $('#isVehicleBrand').is(':checked'));
                formData.append('IsPartBrand', $('#isPartBrand').is(':checked'));
                formData.append('IsToyBrand', $('#isToyBrand').is(':checked'));
                
                var imageFile = $('#brandImage')[0].files[0];
                if (imageFile) {
                    formData.append('imageFile', imageFile);
                }

                $.ajax({
                    url: '@Url.Action("SaveBrand", "Brand")',
                    type: 'POST',
                    contentType: false,
                    processData: false,
                    data: formData,
                    success: function(res) {
                        if (res.success) {
                            brandModal.hide();
                            showToast(res.message);
                            
                            var brand = res.data;
                            var scopesHtml = '';
                            if (brand.isVehicleBrand) scopesHtml += '<span class="badge bg-danger text-uppercase badge-vehicle" style="font-size:0.75rem; margin-right: 0.5rem;">Sản Xuất Xe</span>';
                            if (brand.isPartBrand) scopesHtml += '<span class="badge bg-primary text-uppercase badge-part" style="font-size:0.75rem; margin-right: 0.5rem;">Sản Xuất Phụ Tùng</span>';
                            if (brand.isToyBrand) scopesHtml += '<span class="badge bg-warning text-dark text-uppercase badge-toy" style="font-size:0.75rem;">Sản Xuất Đồ Chơi</span>';

                            if (formData.Id === 0) {
                                // Thêm mới dòng vào đầu bảng
                                var newRowHtml = `
                                    <tr id="brand-row-${brand.id}" 
                                        data-id="${brand.id}" 
                                        data-name="${brand.name}" 
                                        data-country="${formData.CountryId}" 
                                        data-vehicle="${brand.isVehicleBrand}" 
                                        data-part="${brand.isPartBrand}" 
                                        data-toy="${brand.isToyBrand}"
                                        data-image="${brand.imageUrl || ''}"
                                        class="row-highlight-add">
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                ${brand.imageUrl
                                                    ? `<img src="${brand.imageUrl}" alt="${brand.name}" class="brand-logo-cell" style="width:42px;height:42px;object-fit:contain;border-radius:6px;border:1px solid rgba(255,255,255,0.1);background:#fff;flex-shrink:0;padding:3px;" />`
                                                    : `<div style="width:42px;height:42px;background:rgba(255,255,255,0.06);border-radius:6px;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-size:1.1rem;opacity:0.4;">🏷️</span></div>`}
                                                <div class="fw-bold fs-5 brand-name-cell">${brand.name}</div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary py-2 px-3 brand-country-cell">${brand.countryName}</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2 brand-scopes-cell">${scopesHtml}</div>
                                        </td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-warning border-0 me-1 fw-bold" onclick="openEditBrandModal(${brand.id})">Sửa</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 fw-bold" onclick="deleteBrandAjax(${brand.id})">Xóa</button>
                                        </td>
                                    </tr>
                                `;
                                $('#brandsTableBody').prepend(newRowHtml);
                                
                                // Xóa hiệu ứng highlight sau khi chạy xong
                                setTimeout(function() {
                                    $(`#brand-row-${brand.id}`).removeClass('row-highlight-add');
                                }, 2000);
                            } else {
                                // Cập nhật dòng hiện tại
                                var $row = $(`#brand-row-${brand.id}`);
                                $row.attr('data-name', brand.name);
                                $row.attr('data-country', formData.CountryId);
                                $row.attr('data-vehicle', brand.isVehicleBrand);
                                $row.attr('data-part', brand.isPartBrand);
                                $row.attr('data-toy', brand.isToyBrand);
                                if (brand.imageUrl) $row.attr('data-image', brand.imageUrl);
                                
                                var logoHtml = brand.imageUrl
                                    ? `<img src="${brand.imageUrl}" alt="${brand.name}" class="brand-logo-cell" style="width:42px;height:42px;object-fit:contain;border-radius:6px;border:1px solid rgba(255,255,255,0.1);background:#fff;flex-shrink:0;padding:3px;" />`
                                    : ($row.attr('data-image')
                                        ? `<img src="${$row.attr('data-image')}" alt="${brand.name}" class="brand-logo-cell" style="width:42px;height:42px;object-fit:contain;border-radius:6px;border:1px solid rgba(255,255,255,0.1);background:#fff;flex-shrink:0;padding:3px;" />`
                                        : `<div style="width:42px;height:42px;background:rgba(255,255,255,0.06);border-radius:6px;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-size:1.1rem;opacity:0.4;">🏷️</span></div>`);
                                
                                $row.find('td:first').html(`<div class="d-flex align-items-center gap-3">${logoHtml}<div class="fw-bold fs-5 brand-name-cell">${brand.name}</div></div>`);
                                $row.find('.brand-country-cell').text(brand.countryName);
                                $row.find('.brand-scopes-cell').html(scopesHtml);
                                
                                $row.addClass('row-highlight-edit');
                                
                                setTimeout(function() {
                                    $row.removeClass('row-highlight-edit');
                                }, 2000);
                            }
                        } else {
                            $('#errorMessage').removeClass('d-none').text(res.message);
                        }
                    },
                    error: function() {
                        $('#errorMessage').removeClass('d-none').text('Không thể kết nối đến máy chủ. Vui lòng thử lại!');
                    }
                });
            });
        });

        function showToast(msg) {
            $('#toastMessage').text(msg);
            appToast.show();
        }

        function openAddBrandModal() {
            $('#brandModalLabel').text('Thêm Thương Hiệu Mới');
            $('#brandId').val(0);
            $('#brandName').val('');
            $('#brandCountry').val($('#brandCountry option:first').val());
            $('#isVehicleBrand').prop('checked', false);
            $('#isPartBrand').prop('checked', false);
            $('#isToyBrand').prop('checked', false);
            $('#brandImage').val('');
            $('#errorMessage').addClass('d-none').text('');
            brandModal.show();
        }

        function openEditBrandModal(id) {
            var $row = $(`#brand-row-${id}`);
            if ($row.length === 0) return;

            var name = $row.attr('data-name');
            var countryId = $row.attr('data-country');
            var isVehicle = $row.attr('data-vehicle') === 'true';
            var isPart = $row.attr('data-part') === 'true';
            var isToy = $row.attr('data-toy') === 'true';

            $('#brandModalLabel').text('Cập Nhật Thương Hiệu');
            $('#brandId').val(id);
            $('#brandName').val(name);
            $('#brandCountry').val(countryId);
            $('#isVehicleBrand').prop('checked', isVehicle);
            $('#isPartBrand').prop('checked', isPart);
            $('#isToyBrand').prop('checked', isToy);
            $('#brandImage').val('');
            $('#errorMessage').addClass('d-none').text('');
            
            brandModal.show();
        }

        function deleteBrandAjax(id) {
            var $row = $(`#brand-row-${id}`);
            var name = $row.attr('data-name') || 'thương hiệu này';
            
            if (confirm(`Bạn có chắc chắn muốn xóa hãng "${name}"? Việc xóa hãng có thể ảnh hưởng tới các sản phẩm liên quan.`)) {
                $.ajax({
                    url: '@Url.Action("DeleteBrandAjax", "Brand")/' + id,
                    type: 'POST',
                    success: function(res) {
                        if (res.success) {
                            showToast(res.message);
                            $row.css('background-color', 'rgba(255, 40, 40, 0.15)')
                                .fadeOut(500, function() {
                                    $(this).remove();
                                });
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function() {
                        alert('Không thể thực hiện yêu cầu xóa. Vui lòng thử lại!');
                    }
                });
            }
        }
    </script>
}
