@startuml
hide circle
skinparam linetype ortho

entity "maintenance_services" {
  * id : INT <<PK>>
  --
  * name : VARCHAR(255)
  base_price : DECIMAL(12,2)
  estimated_duration : INT
}

entity "bookings" {
  * id : UUID <<PK>>
  --
  * customer_id : UUID <<FK>>
  * vehicle_id : BIGINT <<FK>> 
  * service_id : INT <<FK>>
  * technician_id : UUID <<FK>>
  * scheduled_at : DATETIME
  status : VARCHAR(20)
  deposit_amount : DECIMAL(10,2)
}

maintenance_services ||--o{ bookings
@enduml