@model AutoHub.Models.Entities.User

@{
    ViewData["Title"] = "Không Gian Thành Viên - AutoHub";
}

<div class="container px-4 py-5">
    <div class="row g-4 mb-5">
        <div class="col-lg-4">
            <div class="premium-card text-center py-5">
                <div class="mb-4 d-inline-block rounded-circle bg-dark text-white d-flex align-items-center justify-content-center mx-auto" style="width: 90px; height: 90px; font-size: 2.5rem; font-weight:800;">
                    @Model.FirstName[0]
                </div>
                <h3 style="font-weight: 800;">@Model.LastName @Model.FirstName</h3>
                <p class="text-muted">Thành Viên Cao Cấp</p>
                <hr class="my-4" />
                <div class="text-start">
                    <p class="mb-2"><strong>Email:</strong> @(Model.Email ?? "Chưa thiết lập")</p>
                    <p class="mb-2"><strong>Số Điện Thoại:</strong> @(Model.PhoneNumber ?? "Chưa thiết lập")</p>
                    <p class="mb-4"><strong>Địa Chỉ:</strong> @Model.HouseNumber, @Model.StreetName, @Model.Ward, @Model.District, @Model.City</p>
                </div>
                <button class="btn-premium-dark w-100" onclick="openSecureUpdateModal()">Đổi Thông Tin Liên Hệ</button>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="premium-card mb-4">
                <h4 class="text-uppercase mb-4" style="font-weight: 900; letter-spacing: -0.5px;">Tiến Trình Thành Viên</h4>
                <div class="p-3 border rounded bg-white mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted" style="font-size:0.85rem; font-weight:700;">HẠNG ĐÃ ĐẠT</span>
                        <span class="text-danger" style="font-size:0.85rem; font-weight:700;">TIẾN TRÌNH ƯU ĐÃI KẾ TIẾP</span>
                    </div>
                    <div class="circuit-progress mb-3">
                        <div class="circuit-progress-bar" style="width: 75%;"></div>
                    </div>
                    <div class="d-flex justify-content-between text-muted" style="font-size: 0.8rem;">
                        <span>Bronze (Giảm 0%)</span>
                        <span>Silver (Giảm 2%)</span>
                        <span class="text-danger" style="font-weight:700;">Gold (Giảm 5%)</span>
                        <span>Diamond (Giảm 10%)</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="p-2 border rounded text-center flex-grow-1">
                        <div style="font-weight:800; font-size:1.5rem;" class="text-danger">5%</div>
                        <div class="text-muted" style="font-size:0.75rem;">Giảm giá Xe & Phụ Tùng hiện tại</div>
                    </div>
                    <div class="p-2 border rounded text-center flex-grow-1">
                        <div style="font-weight:800; font-size:1.5rem;">0 đ</div>
                        <div class="text-muted" style="font-size:0.75rem;">Phí kiểm định xe định kỳ</div>
                    </div>
                </div>
            </div>

            <div class="premium-card">
                <nav>
                    <div class="nav nav-tabs border-bottom mb-4" id="nav-tab" role="tablist">
                        <button class="nav-link active border-0 bg-transparent text-dark font-weight-bold" id="nav-purchase-tab" data-bs-toggle="tab" data-bs-target="#nav-purchase" type="button" role="tab" style="font-weight: 800; text-transform:uppercase;">Lịch Sử Mua Xe</button>
                        <button class="nav-link border-0 bg-transparent text-dark font-weight-bold" id="nav-service-tab" data-bs-toggle="tab" data-bs-target="#nav-service" type="button" role="tab" style="font-weight: 800; text-transform:uppercase;">Lịch Sử Chăm Sóc / Dịch Vụ</button>
                    </div>
                </nav>
                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane fade show active" id="nav-purchase" role="tabpanel">
                        <table class="table align-middle">
                            <thead>
                                <tr class="text-muted text-uppercase" style="font-size:0.8rem;">
                                    <th>Dòng Xe</th>
                                    <th>Ngày Mua</th>
                                    <th>Giá Trị</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Honda Civic (Sedan)</strong></td>
                                    <td>15/04/2026</td>
                                    <td class="text-danger" style="font-weight: 700;">730.000.000 đ</td>
                                    <td><span class="badge bg-success">Đã bàn giao</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="tab-pane fade" id="nav-service" role="tabpanel">
                        <table class="table align-middle">
                            <thead>
                                <tr class="text-muted text-uppercase" style="font-size:0.8rem;">
                                    <th>Dịch Vụ</th>
                                    <th>Ngày Thực Hiện</th>
                                    <th>Chi Phí</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Rửa xe bọt tuyết & Phủ bóng Nano</strong></td>
                                    <td>18/05/2026</td>
                                    <td class="text-danger" style="font-weight: 700;">150.000.000 đ</td>
                                    <td><span class="badge bg-success">Hoàn thành</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="secureUpdateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background:#F5F5F7;">
            <div class="modal-header border-0 bg-dark text-white rounded-top-4 py-3">
                <h5 class="modal-title font-weight-bold" style="font-weight:800;">Xác Thực Cập Nhật An Toàn (3 Bước)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div id="step1Container">
                    <h6 class="text-uppercase text-danger mb-3" style="font-weight:700; font-size:0.8rem;">BƯỚC 1: Xác Thực Mật Khẩu Tài Khoản</h6>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:0.8rem;">Nhập mật khẩu hiện tại của bạn để tiếp tục</label>
                        <input type="password" id="confirmPasswordInput" class="form-control py-2 border-secondary" placeholder="Mật khẩu hiện tại" />
                    </div>
                    <button class="btn-premium-dark w-100" onclick="verifyPasswordStep()">Tiếp Tục</button>
                </div>

                <div id="step2Container" style="display: none;">
                    <h6 class="text-uppercase text-danger mb-3" style="font-weight:700; font-size:0.8rem;">BƯỚC 2: Nhập Số Điện Thoại / Email MỚI</h6>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:0.8rem;">Số điện thoại mới</label>
                        <input type="text" id="newPhoneInput" class="form-control py-2 border-secondary" placeholder="Ví dụ: 0987654321" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:0.8rem;">Email mới (Có thể bỏ trống)</label>
                        <input type="email" id="newEmailInput" class="form-control py-2 border-secondary" placeholder="new.email@example.com" />
                    </div>
                    <button class="btn-premium-dark w-100" onclick="verifyUniqueStep()">Gửi Mã Xác Thực OTP</button>
                </div>

                <div id="step3Container" style="display: none;">
                    <h6 class="text-uppercase text-danger mb-3" style="font-weight:700; font-size:0.8rem;">BƯỚC 3: Xác Minh Mã OTP (SIM MỚI)</h6>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:0.8rem;">Hệ thống đã gửi một mã OTP gồm 6 chữ số về Số Điện Thoại mới. Nhập mã để hoàn tất cập nhật.</label>
                        <input type="text" id="otpInput" class="form-control py-2 border-secondary text-center" placeholder="******" style="font-size:1.5rem; letter-spacing:8px; font-weight:800;" />
                    </div>
                    <button class="btn-premium-dark w-100" onclick="submitOtpUpdate()">Xác Nhận & Cập Nhật</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openSecureUpdateModal() {
            $('#step1Container').show();
            $('#step2Container').hide();
            $('#step3Container').hide();
            $('#confirmPasswordInput').val('');
            $('#newPhoneInput').val('');
            $('#newEmailInput').val('');
            $('#otpInput').val('');
            $('#secureUpdateModal').modal('show');
        }

        function verifyPasswordStep() {
            var password = $('#confirmPasswordInput').val().trim();
            if (!password) {
                alert('Vui lòng nhập mật khẩu xác nhận!');
                return;
            }

            if (password === "123456") {
                $('#step1Container').hide();
                $('#step2Container').show();
            } else {
                alert('Mật khẩu không chính xác! Vui lòng thử lại.');
            }
        }

        function verifyUniqueStep() {
            var newPhone = $('#newPhoneInput').val().trim();
            if (!newPhone) {
                alert('Vui lòng nhập số điện thoại mới!');
                return;
            }

            if (newPhone === "0912345678") {
                alert('Số điện thoại này đã được sử dụng bởi một thành viên khác. Vui lòng nhập số khác!');
            } else {
                alert('Mã OTP đã được gửi thành công đến số điện thoại: ' + newPhone);
                $('#step2Container').hide();
                $('#step3Container').show();
            }
        }

        function submitOtpUpdate() {
            var otp = $('#otpInput').val().trim();
            if (!otp) {
                alert('Vui lòng nhập mã xác thực OTP!');
                return;
            }

            alert('Đổi số điện thoại liên hệ thành công!\nHệ thống đã lưu thông tin mới của bạn.');
            $('#secureUpdateModal').modal('hide');
        }
    </script>
}
