@model AutoHub.Models.Entities.User
<main b-7vnz5sug0f="" role="main" class="">
  <ul class="nav">
    <li class="nav-item ms-3">
            <a class="btn-neon" href="@Url.Action("Logout", "Home")">Đăng Xuất</a>
        </li>
  </ul>
</main>


@{
    ViewData["Title"] = "Không Gian Thành Viên - AutoHub";
}

<div class="container px-4 py-5">
        

    @if (!string.IsNullOrEmpty(ViewBag.Warning))
    {
        <div class="alert alert-warning py-3 mb-4" style="font-size: 0.9rem; border-left: 4px solid var(--accent-gold); background-color: rgba(212, 175, 55, 0.1); color: #856404; border-radius: 0;">
            <i class="me-2 fw-bold">⚠️</i> <strong>Hệ Thống Đang Bảo Trì:</strong> @ViewBag.Warning
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-3 mb-4" style="font-size: 0.9rem; border-left: 4px solid var(--accent-mint); background-color: rgba(46, 229, 157, 0.1); color: var(--accent-mint); border-radius: 0;">
            <i class="me-2 fw-bold">✅</i> @TempData["Success"]
        </div>
    }

    <!-- Alert AJAX -->

    
    <div id="profileAlert" style="display:none;" class="mb-4"></div>

    <div class="row g-4 mb-5">
        <!-- ============ SIDEBAR: Avatar + Thông Tin + Nút ============ -->
        <div class="col-lg-4">
            <div class="tech-panel text-center">

                <!-- Avatar -->
                <div class="mb-4 d-inline-flex rounded-circle bg-dark text-white align-items-center justify-content-center mx-auto"
                     id="avatarCircle"
                     style="width:90px; height:90px; font-size:2.5rem; font-weight:800; border:2px solid var(--accent-gold);">
                    @Model.FirstName?[0]
                </div>

                <h3 class="text-gradient-gold" style="font-weight:800;" id="displayFullName">
                    @Model.LastName @Model.FirstName
                </h3>

                <hr class="my-4" style="border-color: rgba(255,255,255,0.1);" />

                <!-- Thông tin tóm tắt -->
                <div class="text-start mb-4">
                    <p class="mb-2">
                        <strong class="text-muted">Email:</strong> <br />
                        <span id="displayEmail">@(Model.Email ?? "Chưa thiết lập")</span>
                    </p>
                    <p class="mb-2">
                        <strong class="text-muted">Điện Thoại:</strong> <br />
                        <span id="displayPhone">@(Model.PhoneNumber ?? "Chưa thiết lập")</span>
                    </p>
                    <p class="mb-2">
                        <strong class="text-muted">Ngày Sinh:</strong> <br />
                        <span id="displayDob">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa thiết lập")</span>
                    </p>
                    <p class="mb-2">
                        <strong class="text-muted">Giới Tính:</strong> <br />
                        <span id="displayGender">@(Model.Gender ?? "Chưa thiết lập")</span>
                    </p>
                </div>

                <!-- Nút chỉnh sửa thông tin -->
                <button class="btn-neon w-100 mb-2" onclick="openProfileModal()">
                    ✏️ Chỉnh Sửa Thông Tin 
                </button>

            </div>
        </div>

        <!-- ============ CONTENT: Địa Chỉ + Hạng + Lịch Sử ============ -->
        <div class="col-lg-8">

            <!-- Quản lý địa chỉ -->
            <div class="tech-panel mb-4">
                <h4 class="text-uppercase mb-4 text-gradient-gold" style="font-weight: 900; letter-spacing: -0.5px;">
                    Quản Lý Địa Chỉ Giao Nhận
                </h4>

                <form method="post" action="@Url.Action("UpdateAddress", "Home")">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="label-tech">Tỉnh / Thành Phố</label>
                            <select id="City" name="City" class="form-select input-premium w-100" required>
                                <option value="">-- Chọn Tỉnh/Thành --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="label-tech">Quận / Huyện</label>
                            <select id="District" name="District" class="form-select input-premium w-100" required disabled>
                                <option value="">-- Chọn Quận/Huyện --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="label-tech">Phường / Xã</label>
                            <select id="Ward" name="Ward" class="form-select input-premium w-100" disabled>
                                <option value="">-- Chọn Phường/Xã --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="label-tech">Số Nhà / Tên Đường</label>
                        <input type="text" name="HouseNumber" class="form-control input-premium w-100"
                               placeholder="Ví dụ: 123 Đường Lê Lợi" value="@Model.HouseNumber" required />
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn-neon">LƯU ĐỊA CHỈ</button>
                    </div>
                </form>
            </div>

            <!-- Tiến trình hạng thành viên // chưa cần làm đến
            <div class="tech-panel mb-4">
                <h4 class="text-uppercase mb-4" style="font-weight: 900; letter-spacing: -0.5px;">Tiến Trình Đạt Hạng</h4>
                <div class="p-3 border rounded mb-4" style="background: rgba(0,0,0,0.2); border-color: rgba(255,255,255,0.05) !important;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted" style="font-size:0.85rem; font-weight:700;">HẠNG ĐÃ ĐẠT</span>
                        <span class="text-gradient-gold" style="font-size:0.85rem; font-weight:700;">TIẾN TRÌNH ƯU ĐÃI KẾ TIẾP</span>
                    </div>
                    <div class="circuit-progress mb-3">
                        <div class="circuit-progress-bar" style="width: 75%;"></div>
                    </div>
                    <div class="d-flex justify-content-between text-muted" style="font-size: 0.8rem;">
                        <span class="@(Model.RankLevel == "Bronze" ? "text-gradient-gold fw-bold" : "")">Bronze (0%)</span>
                        <span class="@(Model.RankLevel == "Silver" ? "text-gradient-gold fw-bold" : "")">Silver (2%)</span>
                        <span class="@(Model.RankLevel == "Gold" ? "text-gradient-gold fw-bold" : "text-muted")">Gold (5%)</span>
                        <span class="@(Model.RankLevel == "Diamond" ? "text-gradient-gold fw-bold" : "")">Diamond (10%)</span>
                    </div>
                </div>
            </div> -->

            <!-- Lịch sử mua xe -->
            <div class="tech-panel">
                <nav>
                    <div class="nav nav-tabs border-bottom border-secondary mb-4" id="nav-tab" role="tablist">
                        <button class="nav-link active border-0 bg-transparent text-white font-weight-bold"
                                id="nav-purchase-tab" data-bs-toggle="tab" data-bs-target="#nav-purchase"
                                type="button" role="tab" style="font-weight: 800; text-transform:uppercase;">
                            Lịch Sử Mua Xe
                        </button>
                    </div>
                </nav>
                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane fade show active" id="nav-purchase" role="tabpanel">
                        <table class="table table-dark table-hover align-middle bg-transparent">
                            <thead>
                                <tr class="text-muted text-uppercase" style="font-size:0.8rem;">
                                    <th class="bg-transparent border-secondary">Dòng Xe</th>
                                    <th class="bg-transparent border-secondary">Ngày Mua</th>
                                    <th class="bg-transparent border-secondary">Giá Trị</th>
                                    <th class="bg-transparent border-secondary">Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.Orders != null)
                                {
                                    var hasVehicles = false;
                                    foreach (var order in ViewBag.Orders)
                                    {
                                        foreach (var detail in order.OrderDetails)
                                        {
                                            if (detail.ProductType == "Vehicle")
                                            {
                                                hasVehicles = true;
                                                var vehicle = ((IEnumerable<AutoHub.Models.Entities.Vehicle>)ViewBag.Vehicles)
                                                    .FirstOrDefault(v => v.Id == detail.ProductId);
                                                <tr>
                                                    <td class="bg-transparent border-secondary"><strong>@(vehicle?.Name ?? "Dòng xe khác")</strong></td>
                                                    <td class="bg-transparent border-secondary">@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                                    <td class="text-gradient-gold bg-transparent border-secondary" style="font-weight: 700;">@detail.Price.ToString("N0") đ</td>
                                                    <td class="bg-transparent border-secondary"><span class="badge bg-success">Đã bàn giao</span></td>
                                                </tr>
                                            }
                                        }
                                    }
                                    if (!hasVehicles)
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-3 bg-transparent border-secondary">Chưa có giao dịch mua xe.</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3 bg-transparent border-secondary">Chưa có giao dịch mua xe.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ===================== MODAL CHỈNH SỬA THÔNG TIN CÁ NHÂN ===================== -->
<div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4" style="background:#18181c; border: 1px solid rgba(255,255,255,0.1) !important;">
            <div class="modal-header border-0 bg-dark rounded-top-4 py-3 px-4">
                <h5 class="modal-title text-gradient-gold" style="font-weight:900;">✏️ Chỉnh Sửa Thông Tin Liên Hệ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-white">
                <div class="row g-3">
                    <!-- Họ và Tên -->
                    <div class="col-md-6">
                        <label class="label-tech">Họ <span class="text-danger">*</span></label>
                        <input type="text" id="profileLastName" class="form-control input-premium w-100"
                               value="@Model.LastName" placeholder="Nguyễn" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-tech">Tên <span class="text-danger">*</span></label>
                        <input type="text" id="profileFirstName" class="form-control input-premium w-100"
                               value="@Model.FirstName" placeholder="Văn A" />
                    </div>

                    <!-- Giới tính + Ngày sinh -->
                    <div class="col-md-6">
                        <label class="label-tech">Giới Tính</label>
                        <select id="profileGender" class="form-select input-premium w-100">
                            <option value="">-- Chọn --</option>
                            @{
                                var genderVal = Model.Gender ?? "";
                            }
                            @if (genderVal == "Nam")
                            {
                                <option value="Nam" selected>Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            }
                            else if (genderVal == "Nữ")
                            {
                                <option value="Nam">Nam</option>
                                <option value="Nữ" selected>Nữ</option>
                                <option value="Khác">Khác</option>
                            }
                            else if (genderVal == "Khác")
                            {
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác" selected>Khác</option>
                            }
                            else
                            {
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="label-tech">Ngày Sinh</label>
                        <input type="date" id="profileDob" class="form-control input-premium w-100"
                               value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <!-- Email + SĐT -->
                    <div class="col-md-6">
                        <label class="label-tech">Email</label>
                        <input type="email" id="profileEmail" class="form-control input-premium w-100"
                               value="@(Model.Email ?? "")" placeholder="example@gmail.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-tech">Số Điện Thoại</label>
                        <input type="tel" id="profilePhone" class="form-control input-premium w-100"
                               value="@(Model.PhoneNumber ?? "")" placeholder="0987654321" />
                    </div>
                </div>

                <!-- Thông báo lỗi trong modal -->
                <div id="profileModalError" class="mt-3 p-3 rounded" style="display:none; background:rgba(255,80,80,0.1); border:1px solid #ff5050; color:#ff5050; font-size:0.85rem;"></div>

                <div class="d-flex gap-3 mt-4">
                    <button class="btn-neon px-5 py-2 flex-grow-1" onclick="submitProfileUpdate()" id="profileSaveBtn">
                        💾 Lưu Thông Tin
                    </button>
                    <button class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =====================================================================
        // KHỞI TẠO DROPDOWN ĐỊA CHỈ
        // =====================================================================
        var userCity = '@(Html.Raw(Model.City))';
        var userDistrict = '@(Html.Raw(Model.District))';
        var userWard = '@(Html.Raw(Model.Ward))';

        $(document).ready(function () {
            $.get('@Url.Action("GetCities", "Home")', function (cities) {
                var citySelect = $('#City');
                $.each(cities, function (i, city) {
                    citySelect.append($('<option></option>').val(city).text(city));
                });
                if (userCity && userCity !== 'Chưa cập nhật') {
                    citySelect.val(userCity).trigger('change');
                }
            });

            $('#City').change(function () {
                var city = $(this).val();
                var districtSelect = $('#District');
                var wardSelect = $('#Ward');
                districtSelect.empty().append('<option value="">-- Chọn Quận/Huyện --</option>').prop('disabled', true);
                wardSelect.empty().append('<option value="">-- Chọn Phường/Xã --</option>').prop('disabled', true);

                if (city) {
                    $.get('@Url.Action("GetDistricts", "Home")?city=' + encodeURIComponent(city), function (districts) {
                        $.each(districts, function (i, district) {
                            districtSelect.append($('<option></option>').val(district).text(district));
                        });
                        districtSelect.prop('disabled', false);
                        if (userDistrict && userDistrict !== 'Chưa cập nhật') {
                            districtSelect.val(userDistrict).trigger('change');
                            userDistrict = null;
                        }
                    });
                }
            });

            $('#District').change(function () {
                var district = $(this).val();
                var wardSelect = $('#Ward');
                wardSelect.empty().append('<option value="">-- Chọn Phường/Xã --</option>').prop('disabled', true);
                if (district) {
                    $.get('@Url.Action("GetWards", "Home")?district=' + encodeURIComponent(district), function (wards) {
                        $.each(wards, function (i, ward) {
                            wardSelect.append($('<option></option>').val(ward).text(ward));
                        });
                        wardSelect.prop('disabled', false);
                        if (userWard && userWard !== 'Chưa cập nhật') {
                            wardSelect.val(userWard);
                            userWard = null;
                        }
                    });
                }
            });
        });

        // =====================================================================
        // MODAL CHỈNH SỬA THÔNG TIN CÁ NHÂN
        // =====================================================================

        function openProfileModal() {
            document.getElementById('profileModalError').style.display = 'none';
            document.getElementById('profileSaveBtn').disabled = false;
            document.getElementById('profileSaveBtn').textContent = '💾 Lưu Thông Tin';
            $('#profileModal').modal('show');
        }

        function submitProfileUpdate() {
            const firstName = document.getElementById('profileFirstName').value.trim();
            const lastName = document.getElementById('profileLastName').value.trim();
            const gender = document.getElementById('profileGender').value;
            const dob = document.getElementById('profileDob').value;
            const email = document.getElementById('profileEmail').value.trim();
            const phone = document.getElementById('profilePhone').value.trim();
            const errEl = document.getElementById('profileModalError');

            // Validate cơ bản
            if (!firstName || !lastName) {
                errEl.textContent = '⚠️ Vui lòng nhập đầy đủ Họ và Tên!';
                errEl.style.display = 'block';
                return;
            }
            if (email) {
                var emailRegex = new RegExp('^[^\\s@@]+@@[^\\s@@]+\\.[^\\s@@]+$');
                if (!emailRegex.test(email)) {
                    errEl.textContent = '⚠️ Địa chỉ email không hợp lệ!';
                    errEl.style.display = 'block';
                    return;
                }
            }
            if (phone) {
                var phoneRegex = new RegExp('^(0|\\+84)[0-9]{8,10}$');
                if (!phoneRegex.test(phone)) {
                    errEl.textContent = '⚠️ Số điện thoại không hợp lệ (bắt đầu bằng 0 hoặc +84)!';
                    errEl.style.display = 'block';
                    return;
                }
            }
            errEl.style.display = 'none';

            const btn = document.getElementById('profileSaveBtn');
            btn.disabled = true;
            btn.textContent = 'Đang lưu...';

            $.ajax({
                url: '@Url.Action("UpdateProfile", "Home")',
                method: 'POST',
                data: {
                    FirstName: firstName,
                    LastName: lastName,
                    Gender: gender,
                    DateOfBirth: dob || null,
                    Email: email || null,
                    PhoneNumber: phone || null
                },
                success: function (res) {
                    btn.disabled = false;
                    btn.textContent = '💾 Lưu Thông Tin';

                    if (!res.success) {
                        errEl.textContent = '⚠️ ' + res.message;
                        errEl.style.display = 'block';
                        return;
                    }

                    // Đóng modal
                    $('#profileModal').modal('hide');

                    // Cập nhật UI không reload trang
                    const d = res.data;
                    document.getElementById('displayFullName').textContent = d.fullName;
                    document.getElementById('avatarCircle').textContent = d.avatarChar;
                    document.getElementById('displayEmail').textContent = d.email || 'Chưa thiết lập';
                    document.getElementById('displayPhone').textContent = d.phoneNumber || 'Chưa thiết lập';
                    document.getElementById('displayGender').textContent = d.gender || 'Chưa thiết lập';
                    document.getElementById('displayDob').textContent = d.dateOfBirth || 'Chưa thiết lập';

                    // Hiển thị thông báo thành công
                    const alertBox = document.getElementById('profileAlert');
                    alertBox.innerHTML = `<div class="alert py-3" style="border-left:4px solid var(--accent-mint); background:rgba(46,229,157,0.1); color:var(--accent-mint); border-radius:0;">✅ ${res.message}</div>`;
                    alertBox.style.display = 'block';
                    setTimeout(() => alertBox.style.display = 'none', 4000);
                },
                error: function () {
                    btn.disabled = false;
                    btn.textContent = '💾 Lưu Thông Tin';
                    errEl.textContent = '❌ Lỗi kết nối server. Vui lòng thử lại!';
                    errEl.style.display = 'block';
                }
            });
        }
    </script>
}
