@model IEnumerable<AutoHub.Models.Entities.Vehicle>

@{
    ViewData["Title"] = "AutoHub - Bộ Sưu Tập Xe & Dịch Vụ Hạng Sang";
    var services = ViewBag.Services as IEnumerable<AutoHub.Models.Entities.Service> ?? new List<AutoHub.Models.Entities.Service>();
    var districts = ViewBag.Districts as List<string> ?? new List<string>();
}

<div class="hero-banner" style="background: linear-gradient(135deg, #0f0f11 0%, #1c1c22 100%); border-bottom: 3px solid var(--accent-ferrari);">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 style="text-shadow: 0 4px 15px rgba(0,0,0,0.5);">Auto Luxury</h1>
        <p>Khám phá bộ sưu tập siêu xe và dịch vụ chăm sóc đỉnh cao dành riêng cho giới tinh hoa</p>
        <a href="#collection-section" class="btn-neon text-decoration-none">Trải Nghiệm Ngay</a>
    </div>
</div>

<div class="container px-4 py-5" id="collection-section">
    <h2 class="text-uppercase mb-4" style="font-weight: 900; letter-spacing: -0.5px;">Bộ Sưu Tập Xe Sẵn Có</h2>

    @* tìm kiếm = search *@
    <form method="get" action="@Url.Action("Index", "Home")" class="filter-bar">
        <div class="filter-group">
            <label>Phân Loại Xe</label>
            <select name="vehicleType" class="filter-select">
                <option value="">Tất cả</option>
                @if (ViewBag.VehicleTypes != null)
                {
                    foreach (var type in ViewBag.VehicleTypes)
                    {
                        <option value="@type.Code" selected="@(ViewBag.VehicleType == type.Code)">@type.Value</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Dáng Xe</label>
            <input type="text" name="bodyStyle" value="@ViewBag.BodyStyle" placeholder="Ví dụ: Sedan, Underbone..." class="filter-input" />
        </div>
        <div class="filter-group">
            <label>Nhiên Liệu</label>
            <select name="fuelType" class="filter-select">
                <option value="">Tất cả</option>
                @if (ViewBag.FuelTypes != null)
                {
                    foreach (var fuel in ViewBag.FuelTypes)
                    {
                        <option value="@fuel.Code" selected="@(ViewBag.FuelType == fuel.Code)">@fuel.Value</option>
                    }
                }
            </select>
        </div>
        <button type="submit" class="btn-neon py-2">Tìm Kiếm</button>
        <a href="@Url.Action("Index", "Home")" class="btn-neon text-white py-2 text-decoration-none text-center" style="border-color: #888; color: #888 !important;">Xóa Lọc</a>
    </form>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
        @if (Model != null && Model.Any())
        {
            foreach (var vehicle in Model)
            {
                <div class="col">
                    <div class="tech-panel h-100 d-flex flex-column justify-content-between">
                        <div>
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-dark text-uppercase tracking-wider px-2 py-1" style="font-size:0.75rem;">@vehicle.VehicleType</span>
                                @* <span class="badge bg-danger px-2 py-1" style="font-size:0.75rem;">@vehicle.Transmission</span> *@
                            </div>
                            <div class="vehicle-image-wrapper mb-3 text-center" style="overflow: hidden; border-radius: 8px; background: #f8f9fa;">
                                @if (!string.IsNullOrEmpty(vehicle.ImageUrl))
                                {
                                    <img src="@vehicle.ImageUrl" alt="@vehicle.Name" class="img-fluid" style="max-height: 200px; object-fit: contain; width: 100%;" />
                                }
                                else
                                {
                                    <img src="/images/no-image.png" alt="No image available" class="img-fluid" style="max-height: 200px; object-fit: contain;" />
                                }
                            </div>
                            <h3 style="font-weight: 800; font-size: 1.5rem; margin-bottom: 0.5rem;">@vehicle.Name</h3>
                            <p class="text-muted mb-2">Động cơ: @vehicle.EngineType @(vehicle.EngineCapacity.HasValue ? $"({vehicle.EngineCapacity}L/CC)" : "")</p>
                            <p class="text-muted mb-3">Kiểu dáng: @(vehicle.BodyStyle ?? "Tiêu chuẩn")</p>
                            
                            <div class="d-flex flex-wrap gap-1 mb-4">
                                @foreach (var color in vehicle.Colors)
                                {
                                    <span class="badge border text-dark bg-white" style="font-size:0.8rem;">@color.ColorName</span>
                                }
                            </div>
                        </div>

                        <div>
                            <div class="border-top pt-3 d-flex justify-content-between align-items-center">
                                @if (vehicle.Quantity.HasValue && vehicle.Quantity.Value > 0)
                                {
                                    <div>
                                        <div class="text-muted" style="font-size:0.85rem;">Giá Bán Lẻ</div>
                                        <div class="text-danger" style="font-weight: 800; font-size: 1.25rem;">@string.Format("{0:N0}", vehicle.CurrentPrice) đ</div>
                                    </div>
                                    <button class="btn-neon px-3 py-2" onclick="orderProduct('@Html.Raw(vehicle.Name)', '@vehicle.CurrentPrice', 'vehicle')">🛒 Đặt Lịch Mua</button>
                                }
                                else
                                {
                                    <div>
                                        <div class="text-muted" style="font-size:0.85rem;">Trạng thái</div>
                                        <div class="text-muted" style="font-weight: 800; font-size: 1.1rem;">Hết hàng / Sắp về</div>
                                    </div>
                                    <button class="btn-neon px-3 py-2" style="border-color: #888; color: #888;" onclick="alert('Tính năng tư vấn trực tuyến đang được bảo trì. Vui lòng gọi Hotline!')">Liên hệ tư vấn</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Không tìm thấy dòng xe nào khớp với điều kiện lọc.</p>
            </div>
        }
    </div>

   <!-- <div class="row g-4"> -->
   
   <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
    <div class="col-12 col-lg-6">
            <h2 class="text-uppercase mb-4" style="font-weight: 900; letter-spacing: -0.5px;">Dịch Vụ </h2>
            <div class="d-flex flex-column gap-3">
                @foreach (var service in services)
                {
                    <div class="tech-panel d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 style="font-weight: 700; margin: 0 0 0.25rem 0;">@service.ServiceName</h4>
                            <span class="badge bg-secondary text-uppercase" style="font-size:0.75rem;">@service.VehicleType</span>
                        </div>
                        <div class="text-end">
                            @if (service.RequiresQuote)
                            {
                                <div class="text-muted mb-2" style="font-weight:700; font-size:0.9rem;">Cần khảo sát báo giá</div>
                                <button class="btn-neon py-2 px-3" style="border-color: #888; color: #888;" onclick="alert('Tính năng tư vấn trực tuyến đang được bảo trì. Vui lòng gọi Hotline!')">Tư vấn ngay</button>
                            }
                            else
                            {
                                <div class="text-gradient-gold mb-2" style="font-weight: 800; font-size: 1.15rem;">@string.Format("{0:N0}", service.BasePrice) đ</div>
                                <button class="btn-neon py-2 px-3" onclick="orderProduct('@Html.Raw(service.ServiceName)', '@service.BasePrice', 'service')">🛒 Đặt Lịch</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- <div class="col-lg-6">
            <h2 class="text-uppercase mb-4" style="font-weight: 900; letter-spacing: -0.5px;">Địa Chỉ Khách Hàng (Nghị Định 2026)</h2>
            <div class="tech-panel">
                <div class="mb-3">
                    <label class="label-tech">Tỉnh / Thành Phố</label>
                    <select class="form-select input-premium" id="citySelect">
                        <option value="Hồ Chí Minh">Thành phố Hồ Chí Minh</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="label-tech">Quận / Huyện</label>
                    <select class="form-select input-premium" id="districtSelect">
                        <option value="">-- Chọn Quận --</option>
                        @foreach (var dist in districts)
                        {
                            <option value="@dist">@dist</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="label-tech">Phường / Xã</label>
                    <select class="form-select input-premium" id="wardSelect" disabled>
                        <option value="">-- Chọn Phường --</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="label-tech">Số nhà / Đường phố</label>
                    <input type="text" class="form-control input-premium" placeholder="Ví dụ: 123 Nguyễn Văn Bảo" />
                </div>
                <button class="btn-neon w-100" onclick="alert('Đã cập nhật cấu trúc địa chỉ mới của bạn!')">Lưu Địa Chỉ Mới</button>
            </div>
        </div> -->
    </div>
</div>



@section Scripts {
    <script>
        $(document).ready(function() {
            $('#districtSelect').change(function() {
                var district = $(this).val();
                if (district) {
                    $.getJSON('@Url.Action("GetWards", "Home")', { district: district }, function(data) {
                        var wardSelect = $('#wardSelect');
                        wardSelect.empty().append('<option value="">-- Chọn Phường --</option>');
                        $.each(data, function(index, value) {
                            wardSelect.append('<option value="' + value + '">' + value + '</option>');
                        });
                        wardSelect.prop('disabled', false);
                    });
                } else {
                    $('#wardSelect').empty().append('<option value="">-- Chọn Phường --</option>').prop('disabled', true);
                }
            });
        });

        // Thêm xe/dịch vụ vào giỏ hàng (addToCart được định nghĩa trong _Layout.cshtml)
        function orderProduct(name, price, type) {
            if (typeof addToCart === 'function') {
                addToCart(name, price, type || 'vehicle');
            } else {
                alert('Đã đăng ký đặt lịch hẹn cho: ' + name + '\nNhân viên sẽ liên hệ xác nhận sớm!');
            }
        }
    </script>
}

