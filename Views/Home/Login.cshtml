@{
    ViewData["Title"] = "Đăng Nhập - AutoHub";
}

<div class="hero-banner" style="background: linear-gradient(135deg, #0f0f11 0%, #1c1c22 100%); height: 100vh; display: flex; align-items: center; border-radius: 0;">
    <div class="container px-4">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5 col-xl-4">
                <div class="premium-card p-5" style="border-color: var(--accent-ferrari);">
                    <div class="text-center mb-4">
                        <h2 class="text-uppercase mb-2" style="font-weight: 900; letter-spacing: 1px;">AutoHub</h2>
                        <p class="text-muted" style="font-size: 0.9rem;">Hệ thống định danh thành viên</p>
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger py-2 mb-4" style="font-size: 0.85rem; border-left: 4px solid var(--accent-ferrari); background-color: rgba(255, 40, 40, 0.1); color: var(--accent-ferrari); border-radius: 0;">
                            <strong>Lỗi:</strong> @ViewBag.Error
                        </div>
                    }

                    <form method="post" action="@Url.Action("Login", "Home")">
                        <div class="mb-4">
                            <label class="form-label text-uppercase text-muted" style="font-size: 0.75rem; font-weight: 700;">Email hoặc Số điện thoại</label>
                            <input type="text" name="loginInput" class="form-control bg-dark text-white border-secondary py-2" required placeholder="Nhập email hoặc SĐT..." />
                        </div>
                        
                        <div class="mb-5">
                            <label class="form-label text-uppercase text-muted" style="font-size: 0.75rem; font-weight: 700;">Mật khẩu</label>
                            <input type="password" name="password" class="form-control bg-dark text-white border-secondary py-2" required placeholder="••••••••" />
                        </div>

                        <button type="submit" class="btn-premium-dark w-100 py-3 mb-3" style="font-size: 1.1rem; font-weight: 800;">KHỞI ĐỘNG HỆ THỐNG</button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted" style="font-size: 0.85rem;">Chưa có quyền truy cập? <a href="@Url.Action("Register", "Home")" class="text-danger" style="font-weight: 700; text-decoration: none;">Đăng ký thẻ thành viên</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
