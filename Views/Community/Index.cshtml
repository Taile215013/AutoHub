@model IEnumerable<AutoHub.Models.Entities.SocialPost>
@using AutoHub.Models.Entities

@{
    ViewData["Title"] = "Cộng Đồng - AutoHub";
    var currentUser = ViewBag.CurrentUser as User;
}

@section Styles {
    <style>
        .community-page {
            background: linear-gradient(135deg, #111111 0%, #1a1a24 100%);
            min-height: calc(100vh - 64px);
            padding: 2.5rem 0 4rem;
            color: #fff;
        }

        .post-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .post-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3), 0 0 15px rgba(212, 175, 55, 0.1);
            border-color: rgba(212, 175, 55, 0.3);
        }

        .post-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid var(--accent-gold, #d4af37);
            object-fit: cover;
            background: #fff;
            color: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.2rem;
        }

        .post-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 1rem;
        }

        .post-author {
            font-weight: 700;
            font-size: 1.1rem;
            color: #fff;
            margin: 0;
            line-height: 1.2;
        }

        .post-time {
            font-size: 0.8rem;
            color: #aaa;
            margin: 0;
        }

        .post-content {
            font-size: 1.05rem;
            line-height: 1.6;
            color: #ddd;
            margin-bottom: 1rem;
            white-space: pre-wrap;
        }

        .post-image {
            width: 100%;
            max-height: 500px;
            object-fit: contain;
            border-radius: 12px;
            background: rgba(0, 0, 0, 0.5);
            margin-bottom: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Create post box */
        .create-post-box {
            background: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .create-post-input {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 12px;
            resize: none;
        }
        
        .create-post-input:focus {
            background: rgba(0, 0, 0, 0.3);
            border-color: #d4af37;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            color: #fff;
        }

        .image-preview-container {
            display: none;
            position: relative;
            margin-top: 1rem;
        }
        
        .image-preview {
            max-height: 200px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .remove-image-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(255,0,0,0.7);
            color: white;
            border: none;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .btn-upload-image {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            transition: all 0.2s;
        }
        .btn-upload-image:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #d4af37;
            border-color: #d4af37;
        }
        
        .post-action-btn {
            background: transparent;
            border: none;
            color: #aaa;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color 0.2s;
        }
        .post-action-btn:hover {
            color: #d4af37;
        }
    </style>
}

<div class="community-page">
    <div class="container px-4" style="max-width: 800px;">
        
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="text-gradient-gold mb-0" style="font-weight: 900; letter-spacing: 1px;">🌍 Cộng Đồng AutoHub</h2>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: rgba(46,229,157,0.1); border-color: #2ee59d; color: #21a36f;">
                ✅ @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: rgba(255,80,80,0.1); border-color: #ff5050; color: #ff5050;">
                ❌ @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- HỘP ĐĂNG BÀI -->
        @if (currentUser != null)
        {
            <div class="create-post-box">
                <form action="@Url.Action("CreatePost", "Community")" method="post" enctype="multipart/form-data">
                    <div class="d-flex gap-3 mb-3">
                        @if (!string.IsNullOrEmpty(currentUser.AvatarUrl))
                        {
                            <img src="@currentUser.AvatarUrl" class="post-avatar" alt="@currentUser.FirstName" />
                        }
                        else
                        {
                            <div class="post-avatar">
                                @(currentUser.FirstName?.Length > 0 ? currentUser.FirstName[0].ToString().ToUpper() : "U")
                            </div>
                        }
                        <textarea class="form-control create-post-input" name="content" rows="3" placeholder="Bạn đang nghĩ gì về xe cộ hôm nay, @currentUser.FirstName?"></textarea>
                    </div>
                    
                    <div class="image-preview-container" id="imagePreviewContainer">
                        <img id="previewImg" class="image-preview" src="" alt="Preview" />
                        <button type="button" class="remove-image-btn" onclick="clearImage()">×</button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <label class="btn btn-upload-image px-3 py-2 rounded-pill m-0" style="cursor: pointer;">
                            📷 Thêm Ảnh
                            <input type="file" name="imageFile" id="imageUpload" class="d-none" accept="image/*" onchange="previewImage(this)" />
                        </label>
                        
                        <button type="submit" class="btn-neon px-4 py-2" style="border-radius: 20px;">
                            🚀 Đăng Bài
                        </button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="text-center mb-5 p-4 rounded" style="background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,255,255,0.2);">
                <p class="text-muted mb-3">Vui lòng đăng nhập để tham gia thảo luận cùng cộng đồng.</p>
                <a href="@Url.Action("Login", "Account")" class="btn-neon px-4 py-2 text-decoration-none">Đăng Nhập / Đăng Ký</a>
            </div>
        }

        <!-- DANH SÁCH BÀI VIẾT -->
        <div class="posts-list">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center text-muted mt-5">
                    <h3 style="opacity: 0.3; font-size: 4rem; margin-bottom: 1rem;">🍃</h3>
                    <p>Chưa có bài viết nào. Hãy là người đầu tiên đăng bài nhé!</p>
                </div>
            }
            else
            {
                foreach (var post in Model.OrderByDescending(p => p.CreatedAt))
                {
                    <div class="post-card">
                        <div class="post-header">
                            @if (post.User != null && !string.IsNullOrEmpty(post.User.AvatarUrl))
                            {
                                <img src="@post.User.AvatarUrl" class="post-avatar" alt="@post.User.FirstName" />
                            }
                            else
                            {
                                <div class="post-avatar">
                                    @(post.User?.FirstName?.Length > 0 ? post.User.FirstName[0].ToString().ToUpper() : "U")
                                </div>
                            }
                            <div>
                                <h4 class="post-author">
                                    @(post.User?.LastName) @(post.User?.FirstName)
                                    @if(post.User?.RankLevel == "Gold" || post.User?.RankLevel == "Silver")
                                    {
                                        <span style="color: #d4af37; font-size: 0.9rem;" title="Thành viên VIP">✓</span>
                                    }
                                </h4>
                                <p class="post-time">@post.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
                            </div>
                        </div>
                        
                        <div class="post-content">@post.Content</div>
                        
                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" class="post-image" alt="Post Image" loading="lazy" />
                        }

                        <hr style="border-color: rgba(255,255,255,0.1); margin: 1rem 0;" />
                        <div class="d-flex gap-4">
                            <button class="post-action-btn">
                                <span style="font-size: 1.2rem;">❤️</span> Thích
                            </button>
                            <button class="post-action-btn">
                                <span style="font-size: 1.2rem;">💬</span> Bình Luận
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreviewContainer').style.display = 'inline-block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function clearImage() {
            document.getElementById('imageUpload').value = '';
            document.getElementById('imagePreviewContainer').style.display = 'none';
            document.getElementById('previewImg').src = '';
        }
    </script>
}
