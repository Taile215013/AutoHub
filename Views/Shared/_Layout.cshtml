<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoHub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-secondary py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand font-weight-bold tracking-wider text-uppercase" asp-area="" asp-controller="Home" asp-action="Index" style="font-weight:900; letter-spacing:1.5px;">AutoHub</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium" asp-area="" asp-controller="Home" asp-action="Index">Bộ Sưu Tập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium" asp-area="" asp-controller="Home" asp-action="Account">Thành Viên</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium text-danger" asp-area="" asp-controller="Admin" asp-action="Index">Quản Trị Admin</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center gap-3">
                        @using Microsoft.AspNetCore.Http
                        @inject IHttpContextAccessor HttpContextAccessor
                        @{
                            var userId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
                            var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
                        }
                        @if (userId != null)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="text-muted me-2" style="font-size: 0.85rem; margin-top:2px;">Cơ trưởng,</span>
                                <span class="text-white" style="font-weight: 700; font-size: 0.9rem;">@userName</span>
                            </li>
                            <li class="nav-item">
                                <a class="btn-premium-outline py-1 px-3 d-inline-block" style="font-size: 0.75rem; border-color: var(--accent-ferrari); color: var(--accent-ferrari);" href="@Url.Action("Logout", "Home")">TẮT ĐỘNG CƠ (Thoát)</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn-premium-dark py-1 px-4 d-inline-block" style="font-size: 0.8rem;" href="@Url.Action("Login", "Home")">KHỞI ĐỘNG (Đăng nhập)</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid p-0">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary bg-dark text-muted py-4 mt-auto">
        <div class="container px-4 text-center">
            &copy; 2026 - AutoHub - Hệ Thống Vận Hành & Dịch Vụ Ô Tô Hạng Sang
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
