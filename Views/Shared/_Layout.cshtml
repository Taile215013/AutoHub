<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoHub</title>

    <!--
        THỨ TỰ NHÚNG CSS - QUAN TRỌNG, không đổi thứ tự:
        1. Bootstrap  - Framework base (phải đứng đầu)
        2. main.css   - Toàn bộ CSS Client của AutoHub (ghi đè Bootstrap bên dưới)
        3. AutoHub.styles.css - CSS Isolation (.cshtml.css) do .NET Core tự tổng hợp
        4. RenderSection Styles - View con tự chèn CSS riêng nếu cần
    -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoHub.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-secondary py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-uppercase text-gradient-gold" asp-area="" asp-controller="Home" asp-action="Index">AutoHub</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium" asp-area="" asp-controller="Home" asp-action="Index">Bộ Sưu Tập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium" asp-area="" asp-controller="Home" asp-action="Account">Thành Viên</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-weight-medium text-danger" asp-area="" asp-controller="Admin" asp-action="Index">Quản Trị Admin</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center gap-3">
                        @using Microsoft.AspNetCore.Http
                        @inject IHttpContextAccessor HttpContextAccessor
                        @{
                            var userId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
                            var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
                        }
                        @if (userId != null)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="navbar-user-greeting me-2">Cơ trưởng,</span>
                                <span class="navbar-user-name">@userName</span>
                            </li>
                            <li class="nav-item ms-3">
                                <a class="btn-neon" href="@Url.Action("Logout", "Home")">TẮT ĐỘNG CƠ</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn-neon" href="@Url.Action("Login", "Home")">KHỞI ĐỘNG HỆ THỐNG</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid p-0 flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary bg-dark text-muted py-4 mt-auto">
        <div class="container px-4 text-center">
            &copy; 2026 - AutoHub - Hệ Thống Vận Hành & Dịch Vụ Ô Tô Hạng Sang
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
