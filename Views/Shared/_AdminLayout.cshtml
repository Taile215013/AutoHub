<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoHub Admin</title>

    <!--
        THỨ TỰ NHÚNG CSS ADMIN:
        1. Bootstrap  - Framework base
        2. admin.css  - Toàn bộ CSS Admin (không có CSS client)
        3. AutoHub.styles.css - CSS Isolation tự động
        4. RenderSection Styles - View Admin con có thể chèn thêm
    -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoHub.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">
    <!-- KHUNG BAO NGOÀI CỦA TRANG ADMIN (Gồm Sidebar bên trái và Content bên phải) -->
    <div class="admin-layout">
        
        <!-- SIDEBAR: Thanh điều hướng bên trái -->
        <aside class="admin-sidebar" id="sidebar">
            <div class="sidebar-header">
                <!-- Tên thương hiệu — class sidebar-text sẽ bị ẩn khi sidebar thu nhỏ -->
                <span class="fs-4 fw-bold sidebar-brand sidebar-text">AutoHub Db</span>
                <!-- Nút ẩn/hiện Sidebar -->
                <button class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()" title="Mở/Đóng menu">
                    &#9776;
                </button>
            </div>

            <!-- Xác định xem chúng ta đang ở Controller nào để bôi màu mục đó (Menu Active) -->
            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            }

            <!-- DANH SÁCH MENU BÊN TRÁI SIDE BOARD--> 
            <ul class="admin-menu">
                <!-- Mục Dashboard -->
                <li class="admin-menu-item @(currentController == "Dashboard" ? "active" : "")">
                    <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                        <span>📊</span>
                        <span class="sidebar-text">Tổng Quan Dashboard</span>
                    </a>
                </li>
                
                <!-- Mục Quản Lý Xe Ô tô -->
                <li class="admin-menu-item @(currentController == "Vehicle" ? "active" : "")">
                    <a href="@Url.Action("Index", "Vehicle", new { area = "Admin" })">
                        <span>🚗</span>
                        <span class="sidebar-text">Quản Lý Xe</span>
                    </a>
                </li>
                
                <!-- Mục Quản Lý Phụ Tùng -->
                <li class="admin-menu-item @(currentController == "SparePart" ? "active" : "")">
                    <a href="@Url.Action("Index", "SparePart", new { area = "Admin" })">
                        <span>🛠️</span>
                        <span class="sidebar-text">Quản Lý Phụ Tùng</span>
                    </a>
                </li>
                
                <!-- Mục Quản Lý Thương Hiệu -->
                <li class="admin-menu-item @(currentController == "Brand" ? "active" : "")">
                    <a href="@Url.Action("Index", "Brand", new { area = "Admin" })">
                        <span>🏷️</span>
                        <span class="sidebar-text">Quản Lý Thương Hiệu</span>
                    </a>
                </li>

                <!-- Mục Quản Lý Dịch Vụ -->
                <li class="admin-menu-item @(currentController == "Service" ? "active" : "")">
                    <a href="@Url.Action("Index", "Service", new { area = "Admin" })">
                        <span>⚙️</span>
                        <span class="sidebar-text">Quản Lý Dịch Vụ</span>
                    </a>
                </li>

                <!-- Mục Quản Lý Nhân Viên -->
                <li class="admin-menu-item @(currentController == "Employee" ? "active" : "")">
                    <a href="@Url.Action("Index", "Employee", new { area = "Admin" })">
                        <span>👥</span>
                        <span class="sidebar-text">Quản Lý Nhân Viên</span>
                    </a>
                </li>

                <!-- Mục Quản Lý Khách Hàng -->
                <li class="admin-menu-item @(currentController == "Customer" ? "active" : "")">
                    <a href="@Url.Action("Index", "Customer", new { area = "Admin" })">
                        <span>🧑‍💼</span>
                        <span class="sidebar-text">Quản Lý Khách Hàng</span>
                    </a>
                </li>

                <!-- Mục quay về giao diện Cửa hàng -->
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Home", new { area = "" })">
                        <span>🏪</span>
                        <span class="sidebar-text">Xem Cửa Hàng</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- KHU VỰC NỘI DUNG CHÍNH (Nằm bên phải Sidebar) -->
        <main class="admin-content">
            
            <!-- Đây là nơi 'Lắp Ghép' nội dung từ các file View con (Dashboard.cshtml, Index.cshtml,...) vào -->
            <!-- Giống như cái khung tranh, RenderBody() là bức tranh được lồng vào -->
            @RenderBody()

        </main>
    </div>

    <!-- NHÚNG CÁC THƯ VIỆN JAVASCRIPT CHUNG -->
    <!-- JQuery giúp thao tác với HTML dễ hơn (Ví dụ: $('#id').hide()) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Hàm ẩn/hiện Sidebar dùng chung cho toàn bộ giao diện Admin -->
    <script>
        // Toggle (Đảo ngược) trạng thái của Sidebar khi bấm nút
        function toggleSidebar() {
            $('#sidebar').toggleClass('collapsed');
        }
    </script>

    <!-- Cho phép các View con chèn thêm Code JS riêng nếu cần -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
