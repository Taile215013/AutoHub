@model AutoHub.Models.Entities.User

@{
    ViewData["Title"] = "Đăng Ký Thành Viên - AutoHub";
}

<div class="hero-banner" style="background: linear-gradient(135deg, #0f0f11 0%, #1c1c22 100%); min-height: 100vh; display: flex; align-items: center; border-radius: 0; padding: 5rem 0;">
    <div class="container px-4">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-7">
                <div class="tech-panel">
                    <div class="text-center mb-4">
                        <h2 class="text-uppercase mb-2 text-gradient-gold" style="font-weight: 900; letter-spacing: 1px;">Gia Nhập AutoHub</h2>
                        <p class="text-muted" style="font-size: 0.9rem;">Khởi tạo hồ sơ khách hàng V.I.P</p>
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger py-2 mb-4" style="font-size: 0.85rem; border-left: 4px solid var(--accent-ferrari); background-color: rgba(255, 40, 40, 0.1); color: var(--accent-ferrari); border-radius: 0;">
                            <strong>Lỗi:</strong> @ViewBag.Error
                        </div>
                    }

                    <form method="post" action="@Url.Action("Register", "Account")">
                        <div class="mb-3">
                            <label class="label-tech">Tên Đăng Nhập <span class="text-danger">*</span></label>
                            <input type="text" name="Username" value="@Model?.Username" class="form-control input-premium w-100" required placeholder="Viết liền không dấu..." />
                        </div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="label-tech">Họ và chữ lót</label>
                                <input type="text" name="LastName" value="@Model?.LastName" class="form-control input-premium w-100" required placeholder="Nguyễn Văn..." />
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Tên</label>
                                <input type="text" name="FirstName" value="@Model?.FirstName" class="form-control input-premium w-100" required placeholder="A..." />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="label-tech">Ngày Sinh</label>
                                <input type="date" name="DateOfBirth" class="form-control input-premium w-100" />
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Giới tính</label>
                                <select name="Gender" class="form-select input-premium w-100">
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="label-tech">Tỉnh / Thành <span class="text-danger">*</span></label>
                                <select id="regProvince" name="City" class="form-select input-premium w-100" required>
                                    <option value="">— Chọn Tỉnh/Thành —</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Quận / Huyện</label>
                                <select id="regDistrict" name="District" class="form-select input-premium w-100" disabled>
                                    <option value="">— Chọn Quận/Huyện —</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="label-tech">Phường / Xã</label>
                                <select id="regWard" name="Ward" class="form-select input-premium w-100" disabled>
                                    <option value="">— Chọn Phường/Xã —</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Số nhà / Tên đường</label>
                                <input type="text" name="HouseNumber" value="@Model?.HouseNumber"
                                       class="form-control input-premium w-100" placeholder="123 Lê Lợi..." />
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="label-tech">Số điện thoại <span style="text-transform:none; font-size:0.65rem;">(Tùy chọn)</span></label>
                                <input type="text" name="PhoneNumber" value="@Model?.PhoneNumber" class="form-control input-premium w-100" placeholder="0901..." />
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Email <span style="text-transform:none; font-size:0.65rem;">(Tùy chọn)</span></label>
                                <input type="email" name="Email" value="@Model?.Email" class="form-control input-premium w-100" placeholder="example@email.com" />
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="label-tech">Mật khẩu <span class="text-danger">*</span></label>
                                <input type="password" name="Password" class="form-control input-premium w-100" required placeholder="••••••••" />
                            </div>
                            <div class="col-md-6">
                                <label class="label-tech">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input type="password" name="ConfirmPassword" class="form-control input-premium w-100" required placeholder="••••••••" />
                            </div>
                        </div>

                        <button type="submit" class="btn-neon w-100 py-3 mb-3" style="font-size: 1.1rem;">XÁC NHẬN HỒ SƠ</button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted" style="font-size: 0.85rem;">Đã sở hữu thẻ thành viên? <a href="@Url.Action("Login", "Account")" class="text-gradient-gold" style="font-weight: 700; text-decoration: none;">Đăng nhập ngay</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // Tải danh sách tỉnh
    fetch('@Url.Action("GetProvinces","Home")')
        .then(r => r.json())
        .then(list => {
            const sel = document.getElementById('regProvince');
            list.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.name;
                opt.textContent = p.name;
                opt.setAttribute('data-code', p.code);
                sel.appendChild(opt);
            });
        });

    document.getElementById('regProvince').addEventListener('change', function () {
        const opt  = this.options[this.selectedIndex];
        const code = opt ? opt.getAttribute('data-code') : '';
        const dist = document.getElementById('regDistrict');
        const ward = document.getElementById('regWard');
        dist.innerHTML = '<option value="">— Chọn Quận/Huyện —</option>';
        dist.disabled = true;
        ward.innerHTML = '<option value="">— Chọn Phường/Xã —</option>';
        ward.disabled = true;
        if (!code) return;
        fetch('@Url.Action("GetDistrictsByProvince","Home")?provinceCode=' + encodeURIComponent(code))
            .then(r => r.json())
            .then(list => {
                list.forEach(d => {
                    const o = document.createElement('option');
                    o.value = d.name; o.textContent = d.name;
                    o.setAttribute('data-code', d.code);
                    dist.appendChild(o);
                });
                dist.disabled = false;
            });
    });

    document.getElementById('regDistrict').addEventListener('change', function () {
        const opt  = this.options[this.selectedIndex];
        const code = opt ? opt.getAttribute('data-code') : '';
        const ward = document.getElementById('regWard');
        ward.innerHTML = '<option value="">— Chọn Phường/Xã —</option>';
        ward.disabled = true;
        if (!code) return;
        fetch('@Url.Action("GetWardsByDistrict","Home")?districtCode=' + encodeURIComponent(code))
            .then(r => r.json())
            .then(list => {
                list.forEach(w => {
                    const o = document.createElement('option');
                    o.value = w.name; o.textContent = w.name;
                    ward.appendChild(o);
                });
                ward.disabled = false;
            });
    });
})();
</script>
}
