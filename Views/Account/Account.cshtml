@model AutoHub.Models.Entities.User
@using AutoHub.Models.Entities

@{
    ViewData["Title"] = "Không Gian Thành Viên - AutoHub";
    var queryTab = Context.Request.Query["tab"].ToString();
    var activeTab = TempData["ActiveTab"]?.ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = queryTab;
    if (string.IsNullOrEmpty(activeTab)) activeTab = "profile";
}

@section Styles {
<style>
/* ── Account Layout ──────────────────────────────────────────────────── */
.account-page { background: transparent; min-height: calc(100vh - 64px); padding: 2.5rem 0 4rem; }
.account-sidebar { position: sticky; top: 1.5rem; }

/* Avatar */
.avatar-ring { width:88px; height:88px; border-radius:50%; background:var(--glass-bg, #fff);
               border:2.5px solid var(--accent-gold,#d4af37);
               display:flex; align-items:center; justify-content:center;
               font-size:2.2rem; font-weight:800; color:var(--color-text-primary, #111); margin:0 auto; }
.rank-badge { display:inline-block; padding:3px 12px; border-radius:20px; font-size:.72rem;
              font-weight:700; letter-spacing:.5px; text-transform:uppercase; }
.rank-bronze { background:rgba(205,127,50,.18); color:#cd7f32; border:1px solid #cd7f32; }
.rank-silver { background:rgba(192,192,192,.18); color:#888; border:1px solid #c0c0c0; }
.rank-gold   { background:rgba(212,175,55,.18);  color:#d4af37; border:1px solid #d4af37; }

/* Sidebar nav */
.account-nav .nav-link { color:var(--color-text-muted, #666); font-weight:600; font-size:.83rem;
                          letter-spacing:.5px; text-transform:uppercase; border-radius:8px;
                          padding:.65rem 1rem; transition:all .2s; display:flex; align-items:center; gap:10px; }
.account-nav .nav-link:hover  { color:var(--color-text-primary, #111); background:rgba(0,0,0,.04); }
.account-nav .nav-link.active { color:#d4af37; background:rgba(212,175,55,.1); border-left:3px solid #d4af37; }
.account-nav .nav-link .icon  { font-size:1rem; width:20px; text-align:center; }

/* Content panels */
.tab-content-area { display:none; }
.tab-content-area.active { display:block; }

/* Form labels */
.label-sm { font-size:.72rem; font-weight:700; letter-spacing:.6px; text-transform:uppercase;
             color:var(--color-text-muted, #666); margin-bottom:.35rem; display:block; }

/* Address cascade selects */
select.input-premium:disabled { opacity:.35; cursor:not-allowed; }

/* History table */
.history-table th { font-size:.72rem; letter-spacing:.5px; text-transform:uppercase;
                    color:var(--color-text-muted, #666); font-weight:600; }
.status-badge { padding:3px 10px; border-radius:12px; font-size:.72rem; font-weight:700; }
.status-done  { background:rgba(46,229,157,.15); color:#21a36f; border:1px solid #2ee59d; }

/* Post form */
.color-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(0,0,0,.04);
              border:1px solid rgba(0,0,0,.1); border-radius:20px;
              padding:4px 10px; font-size:.78rem; cursor:default; }
.color-tag .remove { cursor:pointer; color:#ff5050; font-weight:700; font-size:1rem; line-height:1; }

/* Alert strip */
.alert-strip { padding:.75rem 1.25rem; border-radius:0; border-left:4px solid; font-size:.88rem; margin-bottom:1.5rem; }
.alert-success-strip { border-color:#2ee59d; background:rgba(46,229,157,.08); color:#21a36f; }
.alert-error-strip   { border-color:#ff5050; background:rgba(255,80,80,.08);   color:#ff5050; }
.alert-warn-strip    { border-color:#d4af37; background:rgba(212,175,55,.08);  color:#d4af37; }

/* Light Theme Overrides for hardcoded text-white in HTML */
.text-white { color: var(--color-text-primary, #111) !important; }
hr { border-color: rgba(0,0,0,.1) !important; }
.table-dark { background: transparent !important; --bs-table-bg: transparent; --bs-table-color: var(--color-text-primary); }
.modal-content { background: var(--glass-bg, #fff) !important; border: 1px solid rgba(0,0,0,.1) !important; box-shadow: var(--glass-shadow); }
.modal-body.text-white { color: var(--color-text-primary, #111) !important; }
.btn-close-white { filter: invert(1) grayscale(100%) brightness(200%); }
</style>
}

<div class="account-page">
<div class="container px-4">

    @* ── Global alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert-strip alert-success-strip">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-strip alert-error-strip">❌ @TempData["Error"]</div>
    }
    @if (!string.IsNullOrEmpty(ViewBag.Warning as string))
    {
        <div class="alert-strip alert-warn-strip">⚠️ @ViewBag.Warning</div>
    }

    <div class="row g-4">

        <!-- ══════════════════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════════════════ -->
        <div class="col-lg-3 col-md-4">
            <div class="account-sidebar tech-panel">

                @* Avatar + tên *@
                <div class="text-center mb-4">
                    <div class="position-relative d-inline-block mb-3">
                        <div class="avatar-ring" id="sideAvatarChar" style="@(!string.IsNullOrEmpty(Model.AvatarUrl) ? $"background:url('{Model.AvatarUrl}') center/cover; color:transparent; border-color:var(--accent-gold,#d4af37);" : "")">
                            @(Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString().ToUpper() : "U")
                        </div>
                        <label for="avatarUploadInput" class="position-absolute bottom-0 end-0 bg-dark text-white rounded-circle d-flex align-items-center justify-content-center" style="width:28px; height:28px; cursor:pointer; border:2px solid #fff;" title="Đổi ảnh đại diện">
                            <i style="font-size:12px;">📷</i>
                        </label>
                        <input type="file" id="avatarUploadInput" class="d-none" accept="image/*" />
                    </div>
                    <h5 class="text-gradient-gold mb-1" id="sideFullName" style="font-weight:800;">
                        @Model.LastName @Model.FirstName
                    </h5>
                    <div class="mb-2">
                        @{
                            var rankClass = Model.RankLevel?.ToLower() switch {
                                "silver"  => "rank-silver",
                                "gold"    => "rank-gold",
                                _         => "rank-bronze"
                            };
                        }
                        <span class="rank-badge @rankClass">@(Model.RankLevel ?? "Bronze")</span>
                    </div>
                    <p class="text-muted mb-0" style="font-size:.78rem;">@@<strong>@Model.Username</strong></p>
                </div>

                <hr style="border-color:rgba(255,255,255,.08);" />

                @* Nav tabs *@
                <nav class="account-nav d-flex flex-column gap-1 mt-3">
                    <a href="#" class="nav-link @(activeTab=="profile"?"active":"")" data-tab="profile">
                        <span class="icon">👤</span> Thông Tin Cá Nhân
                    </a>
                    <a href="#" class="nav-link @(activeTab=="address"?"active":"")" data-tab="address">
                        <span class="icon">📍</span> Địa Chỉ Giao Nhận
                    </a>
                    <a href="#" class="nav-link @(activeTab=="orders"?"active":"")" data-tab="orders">
                        <span class="icon">🧾</span> Lịch Sử Đơn Hàng
                    </a>
                    <a href="#" class="nav-link @(activeTab=="post"?"active":"")" data-tab="post">
                        <span class="icon">🚗</span> Quản Lý Tin Đăng
                    </a>
                </nav>

                <hr style="border-color:rgba(255,255,255,.08);" />

                <a href="@Url.Action("Logout","Account")" class="btn btn-sm btn-outline-danger w-100 mt-1">
                    Đăng Xuất
                </a>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════
             CONTENT
        ══════════════════════════════════════════════════════ -->
        <div class="col-lg-9 col-md-8">
            <div id="ajaxAlert" style="display:none;" class="mb-3"></div>

            <!-- ── TAB 1: THÔNG TIN CÁ NHÂN ───────────────────── -->
            <div class="tab-content-area @(activeTab=="profile"?"active":"")" id="tab-profile">
                <div class="tech-panel">
                    <h4 class="text-gradient-gold mb-4" style="font-weight:900;text-transform:uppercase;">
                        👤 Thông Tin Cá Nhân
                    </h4>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <span class="label-sm">Họ &amp; Chữ Lót</span>
                            <p class="text-white fw-600 mb-0" id="dispLastName">@(Model.LastName ?? "—")</p>
                        </div>
                        <div class="col-6">
                            <span class="label-sm">Tên</span>
                            <p class="text-white fw-600 mb-0" id="dispFirstName">@(Model.FirstName ?? "—")</p>
                        </div>
                        <div class="col-6">
                            <span class="label-sm">Giới Tính</span>
                            <p class="text-white mb-0" id="dispGender">@(Model.Gender ?? "Chưa thiết lập")</p>
                        </div>
                        <div class="col-6">
                            <span class="label-sm">Ngày Sinh</span>
                            <p class="text-white mb-0" id="dispDob">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa thiết lập")</p>
                        </div>
                        <div class="col-6">
                            <span class="label-sm">Email</span>
                            <p class="text-white mb-0" id="dispEmail">@(Model.Email ?? "Chưa thiết lập")</p>
                        </div>
                        <div class="col-6">
                            <span class="label-sm">Số Điện Thoại</span>
                            <p class="text-white mb-0" id="dispPhone">@(Model.PhoneNumber ?? "Chưa thiết lập")</p>
                        </div>
                        <div class="col-12 mt-3">
                            <span class="label-sm">Địa Chỉ Hiện Tại</span>
                            <p class="text-white mb-0" id="dispCurrentAddress">
                                @if(!string.IsNullOrWhiteSpace(Model.City))
                                {
                                    @($"{Model.HouseNumber} — {Model.Ward}, {Model.District}, {Model.City}")
                                }
                                else
                                {
                                    @:Chưa thiết lập
                                }
                            </p>
                        </div>
                    </div>

                    <button class="btn-neon px-4" onclick="openProfileModal()">✏️ Chỉnh Sửa</button>
                </div>
            </div>

            <!-- ── TAB 2: ĐỊA CHỈ GIAO NHẬN ──────────────────── -->
            <div class="tab-content-area @(activeTab=="address"?"active":"")" id="tab-address">
                <div class="tech-panel">
                    <h4 class="text-gradient-gold mb-4" style="font-weight:900;text-transform:uppercase;">
                        📍 Địa Chỉ Giao Nhận
                    </h4>

                    @* Địa chỉ hiện tại *@
                    @if (!string.IsNullOrWhiteSpace(Model.City))
                    {
                        <div class="mb-4 p-3 rounded" style="background:rgba(212,175,55,.07); border:1px solid rgba(212,175,55,.2);">
                            <span class="label-sm">Địa Chỉ Hiện Tại</span>
                            <p class="text-white mb-0">
                                @Model.HouseNumber — @Model.Ward, @Model.District, @Model.City
                            </p>
                        </div>
                    }

                    <form method="post" action="@Url.Action("UpdateAddress","Account")" id="addressForm">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="label-sm">Tỉnh / Thành Phố <span class="text-danger">*</span></label>
                                <select id="selProvince" name="City" class="form-select input-premium w-100" required>
                                    <option value="">— Chọn Tỉnh/Thành —</option>
                                    @foreach (Province p in (ViewBag.Provinces as IEnumerable<Province> ?? new List<Province>()))
                                    {
                                        if (p.Name == Model.City)
                                        {
                                            <option value="@p.Name" data-code="@p.Code" selected>@p.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@p.Name" data-code="@p.Code">@p.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Quận / Huyện <span class="text-danger">*</span></label>
                                <select id="selDistrict" name="District" class="form-select input-premium w-100" required disabled>
                                    <option value="">— Chọn Quận/Huyện —</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Phường / Xã</label>
                                <select id="selWard" name="Ward" class="form-select input-premium w-100" disabled>
                                    <option value="">— Chọn Phường/Xã —</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="label-sm">Số Nhà / Tên Đường <span class="text-danger">*</span></label>
                            <input type="text" name="HouseNumber" id="inpHouseNumber"
                                   class="form-control input-premium w-100"
                                   placeholder="Ví dụ: 123 Đường Lê Lợi"
                                   value="@Model.HouseNumber" required />
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn-neon px-5">💾 Lưu Địa Chỉ</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ── TAB 3: LỊCH SỬ ĐƠN HÀNG ───────────────────── -->
            <div class="tab-content-area @(activeTab=="orders"?"active":"")" id="tab-orders">
                <div class="tech-panel">
                    <h4 class="text-gradient-gold mb-4" style="font-weight:900;text-transform:uppercase;">
                        🧾 Lịch Sử Đơn Hàng
                    </h4>

                    @{
                        var orders = ViewBag.Orders as IEnumerable<Order> ?? new List<Order>();
                        var allVehicles = ViewBag.Vehicles as IEnumerable<Vehicle> ?? new List<Vehicle>();
                    }

                    @if (!orders.Any())
                    {
                        <p class="text-muted text-center py-4">Chưa có đơn hàng nào.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle history-table" style="background:transparent;">
                                <thead>
                                    <tr class="border-bottom border-secondary">
                                        <th class="bg-transparent">Sản Phẩm</th>
                                        <th class="bg-transparent">Ngày</th>
                                        <th class="bg-transparent">Loại</th>
                                        <th class="bg-transparent text-end">Giá Trị</th>
                                        <th class="bg-transparent text-center">Trạng Thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in orders)
                                    {
                                        foreach (var detail in order.OrderDetails)
                                        {
                                            var productName = detail.ProductType == "Vehicle"
                                                ? allVehicles.FirstOrDefault(v => v.Id == detail.ProductId)?.Name ?? "Xe không xác định"
                                                : $"Phụ tùng #{detail.ProductId}";
                                            <tr class="border-bottom border-secondary" style="border-color:rgba(255,255,255,.06)!important;">
                                                <td class="bg-transparent"><strong>@productName</strong></td>
                                                <td class="bg-transparent text-muted" style="font-size:.82rem;">@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                                <td class="bg-transparent">
                                                    <span style="font-size:.72rem; padding:2px 8px; border-radius:10px; background:rgba(255,255,255,.07);">
                                                        @detail.ProductType
                                                    </span>
                                                </td>
                                                <td class="bg-transparent text-end text-gradient-gold fw-700">
                                                    @detail.Price.ToString("N0") ₫
                                                </td>
                                                <td class="bg-transparent text-center">
                                                    <span class="status-badge status-done">Đã bàn giao</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ── TAB 4: QUẢN LÝ TIN ĐĂNG ─────────────────────────── -->
            <div class="tab-content-area @(activeTab=="post"?"active":"")" id="tab-post">
                <div class="tech-panel">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="text-gradient-gold mb-0" style="font-weight:900;text-transform:uppercase;">
                            🚗 Quản Lý Tin Đăng
                        </h4>
                        <button class="btn-neon px-4 py-2" data-bs-toggle="modal" data-bs-target="#postVehicleModal">
                            + Đăng Tin Mới
                        </button>
                    </div>

                    @{ var tab4Vehicles = ViewBag.Vehicles as IEnumerable<Vehicle> ?? new List<Vehicle>(); }
                    @if (!tab4Vehicles.Any())
                    {
                        <p class="text-muted text-center py-4">Chưa có tin đăng nào.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle history-table" style="background:transparent;">
                                <thead>
                                    <tr class="border-bottom border-secondary">
                                        <th class="bg-transparent">Hình Ảnh</th>
                                        <th class="bg-transparent">Tên Xe</th>
                                        <th class="bg-transparent text-end">Giá Bán</th>
                                        <th class="bg-transparent text-center">Trạng Thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in tab4Vehicles)
                                    {
                                        <tr class="border-bottom border-secondary" style="border-color:rgba(255,255,255,.06)!important;">
                                            <td class="bg-transparent">
                                                <img src="@(v.ImageUrl ?? "/images/no-image.jpg")" alt="Car" style="width:60px; height:40px; object-fit:cover; border-radius:4px;" />
                                            </td>
                                            <td class="bg-transparent"><strong>@v.Name</strong></td>
                                            <td class="bg-transparent text-end text-gradient-gold fw-700">@v.CurrentPrice.ToString("N0") ₫</td>
                                            <td class="bg-transparent text-center">
                                                <span class="status-badge status-done">Đang hiển thị</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

<!-- ═══════════════════════════════════════════════════════════
     MODAL: ĐĂNG TIN XE
════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="postVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0" style="background:#18181c; border:1px solid rgba(255,255,255,.1)!important;">
            <div class="modal-header border-0 px-4 py-3">
                <h5 class="modal-title text-gradient-gold" style="font-weight:900;">🚗 Đăng Tin Xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-white">
                <form method="post" action="@Url.Action("PostVehicle","Account")" enctype="multipart/form-data" id="postVehicleForm">

                        @* ─ Thông tin cơ bản ─ *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="label-sm">Thương Hiệu <span class="text-danger">*</span></label>
                                <select name="BrandId" id="pv_brand" class="form-select input-premium w-100" required>
                                    <option value="">— Chọn thương hiệu —</option>
                                    @foreach (Brand b in (ViewBag.Brands as IEnumerable<Brand> ?? new List<Brand>()))
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="label-sm">Loại Xe <span class="text-danger">*</span></label>
                                <select name="VehicleType" id="pv_vtype" class="form-select input-premium w-100" required>
                                    <option value="">— Chọn loại xe —</option>
                                    @foreach (SystemDictionary d in (ViewBag.VehicleTypes as IEnumerable<SystemDictionary> ?? new List<SystemDictionary>()))
                                    {
                                        <option value="@d.Code">@d.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="label-sm">Dòng Xe</label>
                                <select name="vehicleNameId" id="pv_vname" class="form-select input-premium w-100">
                                    <option value="">— Chọn hoặc nhập mới bên dưới —</option>
                                    @foreach (VehicleName vn in (ViewBag.VehicleNames as IEnumerable<VehicleName> ?? new List<VehicleName>()))
                                    {
                                        <option value="@vn.Id" data-brand="@vn.BrandId">@vn.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="label-sm">Tên Dòng Xe Mới <span style="font-weight:400; text-transform:none; font-size:.72rem;">(nếu chưa có trong danh sách)</span></label>
                                <input type="text" name="newVehicleName" class="form-control input-premium w-100"
                                       placeholder="Ví dụ: Camry, City, Ranger..." />
                            </div>
                            <div class="col-md-6">
                                <label class="label-sm">Phiên Bản / Trim</label>
                                <input type="text" name="variantName" class="form-control input-premium w-100"
                                       placeholder="Ví dụ: 2.5Q, Wildtrak, Sport..." />
                            </div>
                            <div class="col-md-3">
                                <label class="label-sm">Năm Sản Xuất</label>
                                <input type="number" name="modelYear" class="form-control input-premium w-100"
                                       placeholder="2024" min="1990" max="2030" />
                            </div>
                            <div class="col-md-3">
                                <label class="label-sm">Số Lượng</label>
                                <input type="number" name="Quantity" class="form-control input-premium w-100"
                                       value="1" min="1" required />
                            </div>
                        </div>

                        @* ─ Thông số kỹ thuật ─ *@
                        <hr style="border-color:rgba(255,255,255,.08);" />
                        <p class="label-sm mb-3" style="font-size:.78rem; letter-spacing:.3px;">Thông Số Kỹ Thuật</p>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="label-sm">Kiểu Dáng</label>
                                <select name="BodyStyle" class="form-select input-premium w-100">
                                    <option value="">— Chọn —</option>
                                    @foreach (SystemDictionary d in (ViewBag.BodyStyles as IEnumerable<SystemDictionary> ?? new List<SystemDictionary>()))
                                    {
                                        <option value="@d.Code">@d.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Nhiên Liệu</label>
                                <select name="FuelType" class="form-select input-premium w-100">
                                    <option value="">— Chọn —</option>
                                    @foreach (SystemDictionary d in (ViewBag.FuelTypes as IEnumerable<SystemDictionary> ?? new List<SystemDictionary>()))
                                    {
                                        <option value="@d.Code">@d.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Hộp Số</label>
                                <select name="Transmission" class="form-select input-premium w-100">
                                    <option value="">— Chọn —</option>
                                    @foreach (SystemDictionary d in (ViewBag.Transmissions as IEnumerable<SystemDictionary> ?? new List<SystemDictionary>()))
                                    {
                                        <option value="@d.Code">@d.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Loại Động Cơ</label>
                                <select name="EngineType" class="form-select input-premium w-100">
                                    <option value="">— Chọn —</option>
                                    @foreach (SystemDictionary d in (ViewBag.EngineTypes as IEnumerable<SystemDictionary> ?? new List<SystemDictionary>()))
                                    {
                                        <option value="@d.Code">@d.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Dung Tích (L)</label>
                                <input type="number" name="EngineCapacity" class="form-control input-premium w-100"
                                       step="0.1" min="0" placeholder="1.5" />
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Số Chỗ Ngồi</label>
                                <input type="number" name="SeatingCapacity" class="form-control input-premium w-100"
                                       min="1" max="50" placeholder="5" />
                            </div>
                        </div>

                        @* ─ Giá ─ *@
                        <hr style="border-color:rgba(255,255,255,.08);" />
                        <p class="label-sm mb-3" style="font-size:.78rem; letter-spacing:.3px;">Giá Niêm Yết (VNĐ)</p>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="label-sm">Giá Nhập</label>
                                <input type="number" name="PurchasePrice" class="form-control input-premium w-100"
                                       min="0" placeholder="0" />
                            </div>
                            <div class="col-md-6">
                                <label class="label-sm">Giá Bán <span class="text-danger">*</span></label>
                                <input type="number" name="CurrentPrice" class="form-control input-premium w-100"
                                       min="0" placeholder="0" required />
                            </div>
                        </div>

                        @* ─ Màu sắc ─ *@
                        <hr style="border-color:rgba(255,255,255,.08);" />
                        <p class="label-sm mb-2" style="font-size:.78rem; letter-spacing:.3px;">Màu Sắc</p>

                        <div class="d-flex gap-2 mb-2 flex-wrap" id="colorTagContainer"></div>
                        <div class="d-flex gap-2 mb-4">
                            <input type="text" id="colorInput" class="form-control input-premium"
                                   style="max-width:220px;" placeholder="Nhập màu và Enter..." />
                            <button type="button" class="btn btn-outline-secondary" onclick="addColor()">+ Thêm</button>
                        </div>
                        <div id="colorHiddenInputs"></div>

                        @* ─ Ảnh ─ *@
                        <hr style="border-color:rgba(255,255,255,.08);" />
                        <p class="label-sm mb-3" style="font-size:.78rem; letter-spacing:.3px;">Hình Ảnh</p>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="label-sm">Ảnh Chính</label>
                                <input type="file" name="uploadedFile" class="form-control input-premium w-100"
                                       accept="image/*" />
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Ảnh Thumbnail</label>
                                <input type="file" name="thumbnailFile" class="form-control input-premium w-100"
                                       accept="image/*" />
                            </div>
                            <div class="col-md-4">
                                <label class="label-sm">Ảnh Bổ Sung</label>
                                <input type="file" name="additionalFiles" class="form-control input-premium w-100"
                                       accept="image/*" multiple />
                            </div>
                        </div>

                        @* ─ Mô tả ─ *@
                        <div class="mb-4">
                            <label class="label-sm">Mô Tả Xe</label>
                            <textarea name="Description" rows="4" class="form-control input-premium w-100"
                                      placeholder="Mô tả chi tiết về xe..."></textarea>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn-neon px-5 py-2" style="font-size:1rem;">
                                🚀 Đăng Tin Ngay
                            </button>
                        </div>
                    </form>
            </div>
        </div>
    </div>
</div>

        </div>@* /col content *@
    </div>@* /row *@
</div>@* /container *@
</div>@* /account-page *@

<!-- ═══════════════════════════════════════════════════════════
     MODAL: CHỈNH SỬA THÔNG TIN CÁ NHÂN
════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0" style="background:#18181c; border:1px solid rgba(255,255,255,.1)!important;">
            <div class="modal-header border-0 px-4 py-3">
                <h5 class="modal-title text-gradient-gold" style="font-weight:900;">✏️ Chỉnh Sửa Thông Tin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-white">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="label-sm">Họ &amp; Chữ Lót <span class="text-danger">*</span></label>
                        <input type="text" id="mLastName" class="form-control input-premium w-100"
                               value="@Model.LastName" placeholder="Nguyễn Văn" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-sm">Tên <span class="text-danger">*</span></label>
                        <input type="text" id="mFirstName" class="form-control input-premium w-100"
                               value="@Model.FirstName" placeholder="A" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-sm">Giới Tính</label>
                        <select id="mGender" class="form-select input-premium w-100">
                            @{
                                var g = Model.Gender ?? "";
                                var opts = new[] { "Nam", "Nữ", "Khác" };
                            }
                            @foreach (var opt in opts)
                            {
                                if (opt == g)
                                {
                                    <option value="@opt" selected>@opt</option>
                                }
                                else
                                {
                                    <option value="@opt">@opt</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="label-sm">Ngày Sinh</label>
                        <input type="date" id="mDob" class="form-control input-premium w-100"
                               value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-sm">Email</label>
                        <input type="email" id="mEmail" class="form-control input-premium w-100"
                               value="@(Model.Email ?? "")" placeholder="example@@gmail.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="label-sm">Số Điện Thoại</label>
                        <input type="tel" id="mPhone" class="form-control input-premium w-100"
                               value="@(Model.PhoneNumber ?? "")" placeholder="0987654321" />
                    </div>
                </div>
                <div id="mError" class="mt-3 p-3 rounded" style="display:none; background:rgba(255,80,80,.1); border:1px solid #ff5050; color:#ff5050; font-size:.85rem;"></div>
                <div class="d-flex gap-3 mt-4">
                    <button class="btn-neon flex-grow-1" onclick="submitProfile()" id="mSaveBtn">💾 Lưu Thông Tin</button>
                    <button class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ════════════════════════════════════════════════════════════
// TAB NAVIGATION
// ════════════════════════════════════════════════════════════
const TAB_PARAM = 'tab';

document.querySelectorAll('.account-nav .nav-link').forEach(link => {
    link.addEventListener('click', e => {
        e.preventDefault();
        const tab = link.dataset.tab;
        switchTab(tab);
        history.replaceState(null, '', '?tab=' + tab);
    });
});

function switchTab(tab) {
    document.querySelectorAll('.tab-content-area').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.account-nav .nav-link').forEach(el => el.classList.remove('active'));
    const content = document.getElementById('tab-' + tab);
    if (content) content.classList.add('active');
    const navLink = document.querySelector(`.account-nav .nav-link[data-tab="${tab}"]`);
    if (navLink) navLink.classList.add('active');
}

// ════════════════════════════════════════════════════════════
// ĐỊA CHỈ CASCADE (Province → District → Ward)
// Dùng API mới /Home/GetProvinces|GetDistrictsByProvince|GetWardsByDistrict
// ════════════════════════════════════════════════════════════
const savedDistrict = '@Html.Raw(Model.District)';
const savedWard     = '@Html.Raw(Model.Ward)';

let pendingDistrict = savedDistrict;
let pendingWard     = savedWard;

// Lấy code của tỉnh đang chọn từ option
function getSelectedProvinceCode() {
    const sel = document.getElementById('selProvince');
    const opt = sel.options[sel.selectedIndex];
    return opt ? opt.getAttribute('data-code') : '';
}

document.getElementById('selProvince').addEventListener('change', function () {
    const code = getSelectedProvinceCode();
    const distSel = document.getElementById('selDistrict');
    const wardSel = document.getElementById('selWard');

    distSel.innerHTML = '<option value="">— Đang tải... —</option>';
    distSel.disabled = true;
    wardSel.innerHTML = '<option value="">— Chọn Phường/Xã —</option>';
    wardSel.disabled = true;

    if (!code) return;

    fetch('@Url.Action("GetDistrictsByProvince","Home")?provinceCode=' + encodeURIComponent(code))
        .then(r => r.json())
        .then(list => {
            distSel.innerHTML = '<option value="">— Chọn Quận/Huyện —</option>';
            list.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d.name;
                opt.textContent = d.name;
                opt.setAttribute('data-code', d.code);
                if (pendingDistrict && d.name === pendingDistrict) opt.selected = true;
                distSel.appendChild(opt);
            });
            distSel.disabled = false;
            if (pendingDistrict) {
                distSel.dispatchEvent(new Event('change'));
                pendingDistrict = null;
            }
        });
});

document.getElementById('selDistrict').addEventListener('change', function () {
    const opt = this.options[this.selectedIndex];
    const code = opt ? opt.getAttribute('data-code') : '';
    const wardSel = document.getElementById('selWard');

    wardSel.innerHTML = '<option value="">— Đang tải... —</option>';
    wardSel.disabled = true;

    if (!code) return;

    fetch('@Url.Action("GetWardsByDistrict","Home")?districtCode=' + encodeURIComponent(code))
        .then(r => r.json())
        .then(list => {
            wardSel.innerHTML = '<option value="">— Chọn Phường/Xã —</option>';
            list.forEach(w => {
                const opt = document.createElement('option');
                opt.value = w.name;
                opt.textContent = w.name;
                if (pendingWard && w.name === pendingWard) opt.selected = true;
                wardSel.appendChild(opt);
            });
            wardSel.disabled = false;
            pendingWard = null;
        });
});

// Kích hoạt cascade nếu user đã có dữ liệu
(function () {
    const prov = document.getElementById('selProvince');
    if (prov.value && savedDistrict) {
        prov.dispatchEvent(new Event('change'));
    }
})();

// ════════════════════════════════════════════════════════════
// COLOR TAGS (cho form đăng tin)
// ════════════════════════════════════════════════════════════
const colorSet = new Set();

function addColor() {
    const input = document.getElementById('colorInput');
    const val = input.value.trim();
    if (!val || colorSet.has(val)) { input.value = ''; return; }
    colorSet.add(val);
    renderColorTags();
    input.value = '';
}

document.getElementById('colorInput')?.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); addColor(); }
});

function removeColor(c) {
    colorSet.delete(c);
    renderColorTags();
}

function renderColorTags() {
    const container = document.getElementById('colorTagContainer');
    const hidden    = document.getElementById('colorHiddenInputs');
    container.innerHTML = '';
    hidden.innerHTML = '';
    colorSet.forEach(c => {
        container.insertAdjacentHTML('beforeend',
            `<span class="color-tag">${c}<span class="remove" onclick="removeColor('${c.replace(/'/g,"\\'")}')">×</span></span>`);
        hidden.insertAdjacentHTML('beforeend',
            `<input type="hidden" name="colors" value="${c.replace(/"/g,'&quot;')}" />`);
    });
}

// ════════════════════════════════════════════════════════════
// MODAL THÔNG TIN CÁ NHÂN
// ════════════════════════════════════════════════════════════
function openProfileModal() {
    document.getElementById('mError').style.display = 'none';
    document.getElementById('mSaveBtn').disabled = false;
    document.getElementById('mSaveBtn').textContent = '💾 Lưu Thông Tin';
    new bootstrap.Modal(document.getElementById('profileModal')).show();
}

function submitProfile() {
    const firstName = document.getElementById('mFirstName').value.trim();
    const lastName  = document.getElementById('mLastName').value.trim();
    const gender    = document.getElementById('mGender').value;
    const dob       = document.getElementById('mDob').value;
    const email     = document.getElementById('mEmail').value.trim();
    const phone     = document.getElementById('mPhone').value.trim();
    const errEl     = document.getElementById('mError');

    if (!firstName || !lastName) {
        errEl.textContent = '⚠️ Vui lòng nhập đầy đủ Họ và Tên!';
        errEl.style.display = 'block'; return;
    }
    if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        errEl.textContent = '⚠️ Địa chỉ email không hợp lệ!';
        errEl.style.display = 'block'; return;
    }
    if (phone && !/^(0|\+84)[0-9]{8,10}$/.test(phone)) {
        errEl.textContent = '⚠️ Số điện thoại không hợp lệ!';
        errEl.style.display = 'block'; return;
    }
    errEl.style.display = 'none';

    const btn = document.getElementById('mSaveBtn');
    btn.disabled = true; btn.textContent = 'Đang lưu...';

    $.ajax({
        url: '@Url.Action("UpdateProfile","Account")',
        method: 'POST',
        data: { FirstName: firstName, LastName: lastName, Gender: gender,
                DateOfBirth: dob || null, Email: email || null, PhoneNumber: phone || null },
        success(res) {
            btn.disabled = false; btn.textContent = '💾 Lưu Thông Tin';
            if (!res.success) {
                errEl.textContent = '⚠️ ' + res.message;
                errEl.style.display = 'block'; return;
            }
            bootstrap.Modal.getInstance(document.getElementById('profileModal')).hide();
            const d = res.data;
            // Cập nhật sidebar
            document.getElementById('sideFullName').textContent  = d.fullName;
            document.getElementById('sideAvatarChar').textContent = d.avatarChar;
            // Cập nhật tab profile
            document.getElementById('dispFirstName').textContent = firstName;
            document.getElementById('dispLastName').textContent  = lastName;
            document.getElementById('dispGender').textContent    = d.gender || 'Chưa thiết lập';
            document.getElementById('dispDob').textContent       = d.dateOfBirth || 'Chưa thiết lập';
            document.getElementById('dispEmail').textContent     = d.email || 'Chưa thiết lập';
            document.getElementById('dispPhone').textContent     = d.phoneNumber || 'Chưa thiết lập';
            // Alert
            const alert = document.getElementById('ajaxAlert');
            alert.innerHTML = `<div class="alert-strip alert-success-strip">✅ ${res.message}</div>`;
            alert.style.display = 'block';
            setTimeout(() => alert.style.display = 'none', 4000);
        },
        error() {
            btn.disabled = false; btn.textContent = '💾 Lưu Thông Tin';
            errEl.textContent = '❌ Lỗi kết nối. Vui lòng thử lại!';
            errEl.style.display = 'block';
        }
    });
}

// Avatar Upload
document.getElementById('avatarUploadInput')?.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if(!file) return;

    const formData = new FormData();
    formData.append('avatarFile', file);

    fetch('@Url.Action("UpdateAvatar","Account")', {
        method: 'POST',
        body: formData
    }).then(r => r.json()).then(res => {
        if(res.success) {
            const charDiv = document.getElementById('sideAvatarChar');
            charDiv.style.background = `url('${res.url}') center/cover`;
            charDiv.style.color = 'transparent';
            charDiv.style.borderColor = 'var(--accent-gold,#d4af37)';
            const alert = document.getElementById('ajaxAlert');
            alert.innerHTML = `<div class="alert-strip alert-success-strip">✅ ${res.message}</div>`;
            alert.style.display = 'block';
            setTimeout(() => alert.style.display = 'none', 4000);
        } else {
            alert('Lỗi: ' + res.message);
        }
    }).catch(err => {
        alert('Lỗi kết nối!');
    });
});
</script>
}
