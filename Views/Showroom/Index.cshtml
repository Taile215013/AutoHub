@model IEnumerable<AutoHub.Models.Entities.Showroom>
@{
    ViewData["Title"] = "Hệ Thống Showroom - AutoHub";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map { height: 520px; border-radius: 12px; }
        .showroom-card {
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .showroom-card:hover, .showroom-card.active {
            border-color: var(--accent-gold, #d4af37);
            background: rgba(212,175,55,0.06) !important;
        }
        .leaflet-popup-content-wrapper {
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
    </style>
}

@* ── Hero ── *@
<div style="background:linear-gradient(135deg,#0f0f11 0%,#1a1a24 100%);border-bottom:3px solid var(--accent-ferrari,#e8041d);padding:60px 0;text-align:center;">
    <h1 style="color:#fff;font-weight:900;letter-spacing:-1px;">📍 Hệ Thống Showroom AutoHub</h1>
    <p style="color:rgba(255,255,255,0.6);">Tìm chi nhánh gần bạn nhất — xem xe trực tiếp, tư vấn miễn phí</p>
</div>

<div class="container px-4 py-5">
    <div class="row g-4">

        @* ── Cột trái: danh sách showroom ── *@
        <div class="col-md-4">
            <h5 class="text-uppercase text-muted mb-3" style="font-size:0.82rem;letter-spacing:1px;">
                @Model.Count() Chi Nhánh
            </h5>

            <div class="d-flex flex-column gap-3" id="showroomList">
                @foreach (var s in Model)
                {
                    <div class="showroom-card tech-panel p-3"
                         id="card-@s.Id"
                         onclick="focusShowroom(@s.Id, @(s.Latitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "null"), @(s.Longitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))">
                        <div class="d-flex align-items-start gap-3">
                            @if (!string.IsNullOrEmpty(s.ThumbnailImageUrl))
                            {
                                <img src="@s.ThumbnailImageUrl"
                                     style="width:60px;height:46px;object-fit:cover;border-radius:6px;flex-shrink:0;" />
                            }
                            else
                            {
                                <div style="width:60px;height:46px;background:rgba(255,255,255,0.06);border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.5rem;">📍</div>
                            }
                            <div class="flex-grow-1">
                                <div class="fw-bold mb-1">@s.Name</div>
                                <div class="text-muted" style="font-size:0.82rem;">@s.FullAddress</div>
                                @if (!string.IsNullOrEmpty(s.PhoneNumber))
                                {
                                    <div style="font-size:0.82rem;color:var(--accent-gold,#d4af37);">☎ @s.PhoneNumber</div>
                                }
                                @if (!string.IsNullOrEmpty(s.OpeningHours))
                                {
                                    <div class="text-muted" style="font-size:0.78rem;">🕐 @s.OpeningHours</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── Cột phải: bản đồ Leaflet ── *@
        <div class="col-md-8">
            <div id="map"></div>
            <p class="text-muted mt-2" style="font-size:0.78rem;">
                Dữ liệu bản đồ © <a href="https://www.openstreetmap.org/copyright" target="_blank" class="text-muted">OpenStreetMap</a> contributors
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var map, markers = {};

document.addEventListener('DOMContentLoaded', function () {
    map = L.map('map').setView([16.0, 106.0], 6);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 18
    }).addTo(map);

    // Icon tùy chỉnh màu đỏ
    var redIcon = L.icon({
        iconUrl:    'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png',
        shadowUrl:  'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
        iconSize:   [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34]
    });

    var showrooms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Where(s => s.HasCoordinates).Select(s => new {
            id    = s.Id,
            name  = s.Name,
            addr  = s.FullAddress,
            phone = s.PhoneNumber ?? "",
            hours = s.OpeningHours ?? "",
            lat   = s.Latitude,
            lng   = s.Longitude
        }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }
    ));

    showrooms.forEach(function(s) {
        var popup = `
            <div style="min-width:200px;">
                <b style="font-size:1rem;">${s.name}</b><br>
                <span style="color:#666;font-size:0.85rem;">${s.addr}</span><br>
                ${s.phone ? `<span style="color:#d4af37;">☎ ${s.phone}</span><br>` : ''}
                ${s.hours ? `<span style="color:#888;font-size:0.8rem;">🕐 ${s.hours}</span>` : ''}
            </div>`;

        var m = L.marker([s.lat, s.lng], { icon: redIcon })
            .bindPopup(popup)
            .addTo(map);

        m.on('click', function() { highlightCard(s.id); });
        markers[s.id] = m;
    });

    if (Object.keys(markers).length > 0) {
        var group = L.featureGroup(Object.values(markers));
        map.fitBounds(group.getBounds().pad(0.2));
    }
});

function focusShowroom(id, lat, lng) {
    highlightCard(id);
    if (lat === null || lng === null) return;
    map.setView([lat, lng], 16);
    if (markers[id]) markers[id].openPopup();
}

function highlightCard(id) {
    document.querySelectorAll('.showroom-card').forEach(c => c.classList.remove('active'));
    var card = document.getElementById('card-' + id);
    if (card) { card.classList.add('active'); card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
}
</script>
}
