@model IEnumerable<AutoHub.Models.Entities.Vehicle>

@{
    ViewData["Title"] = "Hệ Thống Quản Trị - AutoHub";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản Trị AutoHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="admin-layout">
        <aside class="admin-sidebar" id="sidebar">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-4 fw-bold tracking-wider text-uppercase sidebar-text" style="letter-spacing:1.5px;">AutoHub Db</span>
                <button class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()">
                    &equiv;
                </button>
            </div>
            <ul class="admin-menu">
                <li class="admin-menu-item">
                    <a href="@Url.Action("Dashboard", "Admin")">
                        <span>📊</span>
                        <span class="sidebar-text">Tổng Quan Dashboard</span>
                    </a>
                </li>
                <li class="admin-menu-item active">
                    <a href="@Url.Action("Index", "Admin")">
                        <span>🚗</span>
                        <span class="sidebar-text">Quản Lý Xe</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("SpareParts", "Admin")">
                        <span>🛠️</span>
                        <span class="sidebar-text">Quản Lý Phụ Tùng</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Brands", "Admin")">
                        <span>🏷️</span>
                        <span class="sidebar-text">Quản Lý Thương Hiệu</span>
                    </a>
                </li>
            </ul>
        </aside>

        <main class="admin-content">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Quản Lý Kho Xe Hơi</h1>
                <a href="@Url.Action("Create", "Admin")" class="btn-premium-dark text-decoration-none">Thêm Xe Mới</a>
            </div>

            <div class="premium-card">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-uppercase text-muted" style="font-size:0.8rem;">
                            <th>Tên Dòng Xe</th>
                            <th>Phân Loại</th>
                            <th>Nhiên Liệu</th>
                            <th>Giá Thu Vào</th>
                            <th>Giá Bán Ra</th>
                            <th>Tồn Kho</th>
                            <th>Màu Sắc</th>
                            <th class="text-end">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vehicle in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@vehicle.Name</div>
                                    <div class="text-muted" style="font-size:0.8rem;">Động cơ: @vehicle.EngineType</div>
                                </td>
                                <td><span class="badge bg-dark">@vehicle.VehicleType</span></td>
                                <td>@vehicle.FuelType</td>
                                <td class="text-secondary fw-semibold">@string.Format("{0:N0}", vehicle.PurchasePrice) đ</td>
                                <td class="text-danger fw-bold">@string.Format("{0:N0}", vehicle.CurrentPrice) đ</td>
                                <td>@(vehicle.Quantity.HasValue ? $"{vehicle.Quantity.Value} chiếc" : "Hết / Sắp về")</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var color in vehicle.Colors)
                                        {
                                            <span class="badge bg-secondary" style="font-size:0.75rem;">@color.ColorName</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end">
                                    <form method="post" action="@Url.Action("Delete", "Admin", new { id = vehicle.Id })" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa xe này?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleSidebar() {
            $('#sidebar').toggleClass('collapsed');
        }
    </script>
</body>
</html>
