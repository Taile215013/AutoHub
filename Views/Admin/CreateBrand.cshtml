@model AutoHub.Models.Entities.Brand

@{
    ViewData["Title"] = "Thêm Thương Hiệu Mới - AutoHub";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thêm Thương Hiệu</title>
    <link class="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="admin-layout">
        <aside class="admin-sidebar" id="sidebar">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-4 fw-bold tracking-wider text-uppercase sidebar-text" style="letter-spacing:1.5px;">AutoHub Db</span>
                <button class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()">
                    &equiv;
                </button>
            </div>
            <ul class="admin-menu">
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Admin")">
                        <span>🚗</span>
                        <span class="sidebar-text">Quản Lý Xe</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("SpareParts", "Admin")">
                        <span>🛠️</span>
                        <span class="sidebar-text">Quản Lý Phụ Tùng</span>
                    </a>
                </li>
                <li class="admin-menu-item active">
                    <a href="@Url.Action("Brands", "Admin")">
                        <span>🏷️</span>
                        <span class="sidebar-text">Quản Lý Thương Hiệu</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Home")">
                        <span>🏪</span>
                        <span class="sidebar-text">Xem Cửa Hàng</span>
                    </a>
                </li>
            </ul>
        </aside>

        <main class="admin-content">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Thêm Thương Hiệu Mới</h1>
                <a href="@Url.Action("Brands", "Admin")" class="btn-premium-outline text-decoration-none">Quay Lại</a>
            </div>

            <div class="premium-card">
                <form method="post" action="@Url.Action("CreateBrand", "Admin")">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tên Thương Hiệu</label>
                            <input type="text" name="Name" class="form-control border-secondary py-2" required placeholder="Ví dụ: Honda, Brembo, Akrapovic" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Quốc Gia Sở Hữu</label>
                            <select name="CountryId" class="form-select border-secondary py-2" required>
                                @if (ViewBag.Countries != null)
                                {
                                    foreach (var country in ViewBag.Countries)
                                    {
                                        <option value="@country.Id">@country.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-12 mt-4">
                            <label class="form-label text-uppercase text-muted mb-3" style="font-size:0.8rem; font-weight:700; display:block;">Lĩnh Vực Hoạt Động (Chọn nhiều lĩnh vực)</label>
                            
                            <div class="d-flex flex-column gap-3 p-3 bg-light rounded border border-secondary">
                                <div class="form-check">
                                    <input class="form-check-input border-secondary" type="checkbox" name="IsVehicleBrand" value="true" id="isVehicleBrand">
                                    <label class="form-check-label text-uppercase" style="font-weight:600; font-size:0.9rem;" for="isVehicleBrand">
                                        🚗 Hãng Sản Xuất Xe (Motorbike hoặc Auto)
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input border-secondary" type="checkbox" name="IsPartBrand" value="true" id="isPartBrand">
                                    <label class="form-check-label text-uppercase" style="font-weight:600; font-size:0.9rem;" for="isPartBrand">
                                        🛠️ Hãng Sản Xuất Phụ Tùng sửa chữa
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input border-secondary" type="checkbox" name="IsToyBrand" value="true" id="isToyBrand">
                                    <label class="form-check-label text-uppercase" style="font-weight:600; font-size:0.9rem;" for="isToyBrand">
                                        🏷️ Hãng Sản Xuất Đồ Chơi / Đồ độ xe
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn-premium-dark w-100 py-3">Lưu Thương Hiệu</button>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleSidebar() {
            $('#sidebar').toggleClass('collapsed');
        }
    </script>
</body>
</html>
