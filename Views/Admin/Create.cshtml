@model AutoHub.Models.Entities.Vehicle

@{
    ViewData["Title"] = "Thêm Xe Mới - AutoHub";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thêm Xe Mới</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="admin-layout">
        <aside class="admin-sidebar" id="sidebar">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-4 fw-bold tracking-wider text-uppercase sidebar-text" style="letter-spacing:1.5px;">AutoHub Db</span>
                <button class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()">
                    &equiv;
                </button>
            </div>
            <ul class="admin-menu">
                <li class="admin-menu-item">
                    <a href="@Url.Action("Dashboard", "Admin")">
                        <span>📊</span>
                        <span class="sidebar-text">Tổng Quan Dashboard</span>
                    </a>
                </li>
                <li class="admin-menu-item active">
                    <a href="@Url.Action("Index", "Admin")">
                        <span>🚗</span>
                        <span class="sidebar-text">Quản Lý Xe</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("SpareParts", "Admin")">
                        <span>🛠️</span>
                        <span class="sidebar-text">Quản Lý Phụ Tùng</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Brands", "Admin")">
                        <span>🏷️</span>
                        <span class="sidebar-text">Quản Lý Thương Hiệu</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Home")">
                        <span>🏪</span>
                        <span class="sidebar-text">Xem Cửa Hàng</span>
                    </a>
                </li>
            </ul>
        </aside>

        <main class="admin-content">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Thêm Xe Ô Tô Mới</h1>
                <a href="@Url.Action("Index", "Admin")" class="btn-premium-outline text-decoration-none">Quay Lại</a>
            </div>

            <div class="premium-card">
                <form method="post" action="@Url.Action("Create", "Admin")">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tên Xe</label>
                            <input type="text" name="Name" class="form-control border-secondary py-2" required placeholder="Ví dụ: Honda Civic, Toyota Camry" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Phân Loại</label>
                            <select name="VehicleType" class="form-select border-secondary py-2" required>
                                @if (ViewBag.VehicleTypes != null)
                                {
                                    foreach (var type in ViewBag.VehicleTypes)
                                    {
                                        <option value="@type.Code">@type.Value</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Nhiên Liệu</label>
                            <select name="FuelType" class="form-select border-secondary py-2" required>
                                @if (ViewBag.FuelTypes != null)
                                {
                                    foreach (var fuel in ViewBag.FuelTypes)
                                    {
                                        <option value="@fuel.Code">@fuel.Value</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Hộp Số</label>
                            <select name="Transmission" class="form-select border-secondary py-2" required>
                                @if (ViewBag.Transmissions != null)
                                {
                                    foreach (var trans in ViewBag.Transmissions)
                                    {
                                        <option value="@trans.Code">@trans.Value</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Hãng Sản Xuất</label>
                            <select name="BrandId" class="form-select border-secondary py-2" required>
                                @if (ViewBag.Brands != null)
                                {
                                    foreach (var brand in ViewBag.Brands)
                                    {
                                        <option value="@brand.Id">@brand.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Loại Động Cơ</label>
                            <select name="EngineType" class="form-select border-secondary py-2" required>
                                @if (ViewBag.EngineTypes != null)
                                {
                                    foreach (var engine in ViewBag.EngineTypes)
                                    {
                                        <option value="@engine.Code">@engine.Value</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Dung Tích Động Cơ</label>
                            <input type="number" step="0.1" name="EngineCapacity" class="form-control border-secondary py-2" placeholder="Ví dụ: 1.5, 150 (Xe điện để trống)" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Số Chỗ Ngồi</label>
                            <input type="number" name="SeatingCapacity" class="form-control border-secondary py-2" required value="5" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Trọng Lượng (kg)</label>
                            <input type="number" step="0.1" name="Weight" class="form-control border-secondary py-2" placeholder="Ví dụ: 1300" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Dáng Xe (Body Style)</label>
                            <select name="BodyStyle" class="form-select border-secondary py-2" required>
                                @if (ViewBag.BodyStyles != null)
                                {
                                    foreach (var body in ViewBag.BodyStyles)
                                    {
                                        <option value="@body.Code">@body.Value</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tồn Kho (Quantity)</label>
                            <input type="number" name="Quantity" class="form-control border-secondary py-2" placeholder="Trống = Hết / Sắp về" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted text-danger" style="font-size:0.8rem; font-weight:700;">Giá Thu Vào (Đại Lý Mua Cũ)</label>
                            <input type="number" step="0.01" name="PurchasePrice" class="form-control border-danger py-2" required placeholder="Nhập giá nhập kho" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted text-success" style="font-size:0.8rem; font-weight:700;">Giá Bán Ra (Niêm Yết)</label>
                            <input type="number" step="0.01" name="CurrentPrice" class="form-control border-success py-2" required placeholder="Nhập giá bán khách hàng" />
                        </div>

                        <div class="col-12 mt-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="text-uppercase" style="font-weight:800; margin:0;">Danh Sách Màu Sắc Xe (Dạng 1NF)</h5>
                                <button type="button" class="btn btn-sm btn-outline-dark" onclick="addColorRow()">+ Thêm Màu Mới</button>
                            </div>
                            <div id="colorContainer" class="d-flex flex-column gap-2">
                                <div class="input-group color-row">
                                    <select name="colors" class="form-select border-secondary" required>
                                        @if (ViewBag.VehicleColors != null)
                                        {
                                            foreach (var color in ViewBag.VehicleColors)
                                            {
                                                <option value="@color.Value">@color.Value</option>
                                            }
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-danger" onclick="removeColorRow(this)">&times;</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn-premium-dark w-100 py-3">Lưu Dữ Liệu Xe</button>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleSidebar() {
            $('#sidebar').toggleClass('collapsed');
        }

        function addColorRow() {
            var optionsHtml = '';
            @if (ViewBag.VehicleColors != null)
            {
                foreach (var color in ViewBag.VehicleColors)
                {
                    <text>optionsHtml += '<option value="@color.Value">@color.Value</option>';</text>
                }
            }
            var row = $('<div class="input-group color-row">' +
                        '<select name="colors" class="form-select border-secondary" required>' +
                        optionsHtml +
                        '</select>' +
                        '<button type="button" class="btn btn-outline-danger" onclick="removeColorRow(this)">&times;</button>' +
                        '</div>');
            $('#colorContainer').append(row);
        }

        function removeColorRow(button) {
            var rows = $('.color-row');
            if (rows.length > 1) {
                $(button).closest('.color-row').remove();
            } else {
                alert('Phải có ít nhất 1 màu cho xe!');
            }
        }
    </script>
</body>
</html>
