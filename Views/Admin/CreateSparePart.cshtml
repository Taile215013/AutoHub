@model AutoHub.Models.Entities.SparePart

@{
    ViewData["Title"] = "Thêm Phụ Tùng Mới - AutoHub";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Thêm Phụ Tùng Mới</h1>
    <a href="@Url.Action("SpareParts", "Admin")" class="btn-premium-outline text-decoration-none">Quay Lại</a>
</div>

            <div class="premium-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-danger p-3 mb-4 rounded">
                        <ul class="mb-0">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form method="post" action="@Url.Action("CreateSparePart", "Admin")" onsubmit="return validatePrices()" enctype="multipart/form-data">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Tên Phụ Tùng / Phụ Kiện</label>
                            <input type="text" name="Name" class="form-control border-secondary py-2" required placeholder="Ví dụ: Phuộc Brembo, Má phanh Nissin, Pô Akrapovic" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Hãng Sản Xuất</label>
                            <select name="BrandId" class="form-select border-secondary py-2" required>
                                @if (ViewBag.Brands != null)
                                {
                                    foreach (var brand in ViewBag.Brands)
                                    {
                                        <option value="@brand.Id">@brand.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Phân Loại Danh Mục</label>
                            <select name="Category" class="form-select border-secondary py-2" required>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories)
                                    {
                                        <option value="@cat.Code">@cat.Value</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase text-muted" style="font-size:0.8rem; font-weight:600;">Số Lượng Nhập Kho</label>
                            <input type="number" name="StockQuantity" class="form-control border-secondary py-2" required value="50" min="0" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label text-uppercase text-info" style="font-size:0.8rem; font-weight:700;">Hình Ảnh (Tối ưu WebP Cloudinary)</label>
                            <input type="file" name="ImageFile" accept="image/*" class="form-control bg-dark text-white border-info py-2" id="imageInputSp" />
                            <div class="mt-2 text-center d-none" id="previewContainerSp">
                                <img id="imagePreviewSp" src="#" alt="Preview" class="img-fluid rounded border border-info" style="max-height: 250px;" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted text-danger" style="font-size:0.8rem; font-weight:700;">Giá Nhập Kho (Giá Gốc từ Hãng)</label>
                            <input type="number" step="0.01" id="costPriceInput" name="CostPrice" class="form-control border-danger py-2" required placeholder="Nhập giá nhập kho" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase text-muted text-success" style="font-size:0.8rem; font-weight:700;">Giá Bán Lẻ Ra Thị Trường</label>
                            <input type="number" step="0.01" id="priceInput" name="Price" class="form-control border-success py-2" required placeholder="Nhập giá bán khách hàng" />
                            <div class="text-danger mt-1 fw-semibold" id="priceValidationError" style="display:none; font-size:0.85rem;">
                                Giá bán ra phải lớn hơn giá gốc nhập vào để đảm bảo có lợi nhuận!
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn-premium-dark w-100 py-3">Lưu Phụ Tùng</button>
                        </div>
                    </div>
                </form>
            </div>

@section Scripts {
    <script>
        // Kiểm tra hợp lệ: Giá bán ra phải lớn hơn giá gốc
        function validatePrices() {
            var cost = parseFloat($('#costPriceInput').val());
            var price = parseFloat($('#priceInput').val());
            if (!isNaN(cost) && !isNaN(price)) {
                if (price <= cost) {
                    $('#priceValidationError').show();
                    $('#priceInput').addClass('is-invalid');
                    return false;
                }
            }
            $('#priceValidationError').hide();
            $('#priceInput').removeClass('is-invalid');
            return true;
        }

        $(document).ready(function() {
            // Tự động kiểm tra giá khi người dùng nhập dữ liệu
            $('#costPriceInput, #priceInput').on('input', function() {
                validatePrices();
            });

            // Hiển thị ảnh xem trước khi Admin chọn file
            $('#imageInputSp').change(function(e) {
                var file = e.target.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreviewSp').attr('src', e.target.result);
                        $('#previewContainerSp').removeClass('d-none');
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#previewContainerSp').addClass('d-none');
                }
            });
        });
    </script>
}
