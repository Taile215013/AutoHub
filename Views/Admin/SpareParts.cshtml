@model IEnumerable<AutoHub.Models.Entities.SparePart>

@{
    ViewData["Title"] = "Quản Lý Phụ Tùng - AutoHub";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản Lý Phụ Tùng</title>
    <link class="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="admin-layout">
        <aside class="admin-sidebar" id="sidebar">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-4 fw-bold tracking-wider text-uppercase sidebar-text" style="letter-spacing:1.5px;">AutoHub Db</span>
                <button class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()">
                    &equiv;
                </button>
            </div>
            <ul class="admin-menu">
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Admin")">
                        <span>🚗</span>
                        <span class="sidebar-text">Quản Lý Xe</span>
                    </a>
                </li>
                <li class="admin-menu-item active">
                    <a href="@Url.Action("SpareParts", "Admin")">
                        <span>🛠️</span>
                        <span class="sidebar-text">Quản Lý Phụ Tùng</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Brands", "Admin")">
                        <span>🏷️</span>
                        <span class="sidebar-text">Quản Lý Thương Hiệu</span>
                    </a>
                </li>
                <li class="admin-menu-item">
                    <a href="@Url.Action("Index", "Home")">
                        <span>🏪</span>
                        <span class="sidebar-text">Xem Cửa Hàng</span>
                    </a>
                </li>
            </ul>
        </aside>

        <main class="admin-content">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h1 class="text-uppercase" style="font-weight:900; letter-spacing:-1px;">Quản Lý Phụ Tùng & Đồ Chơi</h1>
                <a href="@Url.Action("CreateSparePart", "Admin")" class="btn-premium-dark text-decoration-none">Thêm Phụ Tùng</a>
            </div>

            <div class="premium-card">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-uppercase text-muted" style="font-size:0.8rem;">
                            <th>Tên Phụ Tùng</th>
                            <th>Hãng Sản Xuất</th>
                            <th>Phân Loại</th>
                            <th>Giá Nhập Kho (Cost)</th>
                            <th>Giá Bán Ra (Retail)</th>
                            <th>Lợi Nhuận Gộp</th>
                            <th>Tồn Kho</th>
                            <th class="text-end">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var part in Model)
                        {
                            var profit = part.Price - part.CostPrice;
                            <tr>
                                <td>
                                    <div class="fw-bold">@part.Name</div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary py-2 px-3">@(part.Brand != null ? part.Brand.Name : "N/A")</span>
                                </td>
                                <td>
                                    <span class="badge bg-dark">@part.Category</span>
                                </td>
                                <td class="text-secondary fw-semibold">@string.Format("{0:N0}", part.CostPrice) đ</td>
                                <td class="text-success fw-bold">@string.Format("{0:N0}", part.Price) đ</td>
                                <td class="text-danger fw-bold">
                                    +@string.Format("{0:N0}", profit) đ
                                </td>
                                <td>
                                    @if (part.StockQuantity > 10)
                                    {
                                        <span class="text-success fw-semibold">@part.StockQuantity cái</span>
                                    }
                                    else if (part.StockQuantity > 0)
                                    {
                                        <span class="text-warning fw-bold">Chỉ còn @part.StockQuantity cái</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">Hết hàng</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form method="post" action="@Url.Action("DeleteSparePart", "Admin", new { id = part.Id })" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phụ tùng này?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleSidebar() {
            $('#sidebar').toggleClass('collapsed');
        }
    </script>
</body>
</html>
